    h+='<div style="flex:1;"></div>';
    h+='<button data-outprog="'+sc.id+'" title="Mark as generated in your AI video tool" style="background:'+(isDone?'#16a34a22':'transparent')+';border:1px solid '+(isDone?'#16a34a55':'#3f3f46')+';border-radius:20px;color:'+(isDone?'#4ade80':'#71717a')+';font-size:10px;padding:3px 10px;cursor:pointer;font-family:DM Sans,sans-serif;">'+(isDone?'&#10003; Generated':'Mark done')+'</button>';
