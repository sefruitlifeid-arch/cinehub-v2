    h+='<div style="margin-bottom:4px;display:flex;gap:5px;"><span style="background:#0ea5e922;color:#38bdf8;border:1px solid #0ea5e933;display:inline-flex;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;">Seedance</span>'+(hasDlg?'<span class="bA" style="font-size:9px;">&#128172; Dialog</span>':'')+'</div>';
