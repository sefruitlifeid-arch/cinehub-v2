<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0">
<title>CineAI Hub v11</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:"DM Sans",sans-serif;background:#111412;color:#e4e4e7;margin:0;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:#1a1d1a;}::-webkit-scrollbar-thumb{background:#84CC16;border-radius:2px;}
.inp{background:#1a1d1a;border:1px solid #3f3f46;color:#e4e4e7;border-radius:6px;padding:8px 12px;width:100%;font-family:"DM Sans",sans-serif;font-size:13px;transition:border-color .2s;}
.inp:focus{outline:none;border-color:#84CC16;box-shadow:0 0 0 3px #84CC1615;}
.inp::placeholder{color:#52525b;}
select.inp option{background:#1a1d1a;}
textarea.inp{resize:vertical;min-height:70px;}
.lbl{font-size:10px;font-weight:500;color:#71717a;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;display:block;}
.chip{background:#1a1d1a;border:1px solid #3f3f46;color:#71717a;border-radius:20px;padding:4px 11px;cursor:pointer;font-size:11px;transition:all .15s;user-select:none;white-space:nowrap;display:inline-block;}
.chip:hover{border-color:#71717a;color:#e4e4e7;}
.chip.on{background:#84CC1622;border-color:#84CC16;color:#a3e635;font-weight:500;}
.cg{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px;}
.btnP{background:linear-gradient(135deg,#84CC16,#65a30d);color:#0a0f0a;font-weight:600;border:none;border-radius:6px;padding:9px 18px;cursor:pointer;font-size:13px;font-family:"DM Sans",sans-serif;transition:all .2s;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;}
.btnP:hover{transform:translateY(-1px);box-shadow:0 4px 20px #84CC1640;}
.btnP:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
.btnG{background:transparent;color:#71717a;border:1px solid #3f3f46;border-radius:6px;padding:7px 12px;cursor:pointer;font-size:12px;font-family:"DM Sans",sans-serif;transition:all .2s;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;}
.btnG:hover{border-color:#71717a;color:#e4e4e7;background:#ffffff08;}
.btnD{background:transparent;color:#f87171;border:1px solid #7f1d1d44;border-radius:6px;padding:6px 10px;cursor:pointer;font-size:11px;font-family:"DM Sans",sans-serif;transition:all .2s;white-space:nowrap;}
.btnD:hover{background:#7f1d1d22;border-color:#f87171;}
.card{background:#1a1d1a;border:1px solid #2a2e2a;border-radius:10px;padding:16px;}
.pbox{background:#141714;border:1px solid #2a2e2a;border-radius:7px;padding:12px 60px 12px 12px;font-family:"JetBrains Mono",monospace;font-size:11px;color:#a1a1aa;line-height:1.8;position:relative;white-space:pre-wrap;word-break:break-word;min-height:60px;}
.cpBtn{position:absolute;top:8px;right:8px;background:#2a2e2a;color:#71717a;border:none;border-radius:4px;padding:3px 9px;cursor:pointer;font-size:10px;font-family:"DM Sans",sans-serif;transition:all .2s;}
.cpBtn:hover{background:#84CC16;color:#0a0f0a;}
.cpBtn.ok{background:#16a34a;color:#fff;}
.bA{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:#84CC1622;color:#a3e635;border:1px solid #84CC1633;}
.bB{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:#3b82f622;color:#60a5fa;border:1px solid #3b82f633;}
.bP{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:#7c3aed22;color:#a78bfa;border:1px solid #7c3aed33;}
.bG{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:#16a34a22;color:#4ade80;border:1px solid #16a34a33;}
.tbtn{padding:6px 14px;font-size:11px;font-weight:500;border-radius:5px;cursor:pointer;transition:all .2s;color:#71717a;background:transparent;border:1px solid transparent;font-family:"DM Sans",sans-serif;white-space:nowrap;}
.tbtn.on{background:#84CC16;color:#0a0f0a;border-color:#84CC16;}
.tbtn:hover:not(.on){color:#e4e4e7;border-color:#3f3f46;}
.tcnt{display:none;}.tcnt.on{display:block;}
.panel{display:none;}.panel.on{display:block;}
.divL{border:none;border-top:1px solid #2a2e2a;margin:14px 0;}
.film{background:repeating-linear-gradient(90deg,#141714 0,#141714 10px,#2a2e2a 10px,#2a2e2a 12px);height:3px;}
.ptCard{background:#1a1d1a;border:2px solid #2a2e2a;border-radius:9px;padding:12px 10px;cursor:pointer;transition:all .2s;text-align:center;}
.ptCard:hover{border-color:#84CC1655;background:#84CC1608;}
.ptCard.on{border-color:#84CC16;background:#84CC1612;}
.aiTab{padding:6px 14px;border-radius:5px;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s;border:1px solid #3f3f46;background:transparent;color:#71717a;font-family:"DM Sans",sans-serif;}
.aiTab.on{background:#84CC1622;border-color:#84CC16;color:#a3e635;}
.scCard{background:#1a1d1a;border:1px solid #2a2e2a;border-radius:10px;overflow:hidden;margin-bottom:10px;}
.sBox{background:#141714;border:1px solid #84CC1633;border-radius:8px;padding:14px;font-family:"JetBrains Mono",monospace;font-size:11px;color:#a1a1aa;line-height:1.7;min-height:80px;white-space:pre-wrap;word-break:break-word;}
.optHdr{display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
.optBody{display:none;margin-top:12px;}.optBody.op{display:block;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;}
@media(max-width:700px){.g4,.g3{grid-template-columns:1fr 1fr;}.g2{grid-template-columns:1fr;}}
@media(max-width:420px){.g4,.g3,.g2{grid-template-columns:1fr;}}
#nav{display:flex;align-items:center;gap:6px;padding:10px 0;margin-bottom:4px;overflow-x:auto;-webkit-overflow-scrolling:touch;}
#nav::-webkit-scrollbar{height:0;}
.navBtn{padding:7px 16px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid #3a3e3a;background:transparent;color:#71717a;font-family:"DM Sans",sans-serif;white-space:nowrap;transition:all .2s;}
.navBtn:hover:not(.on){border-color:#71717a;color:#e4e4e7;}
.navBtn[data-nav="story"].on{background:#84CC16;color:#0a0f0a;border-color:#84CC16;}
.navBtn[data-nav="scenes"].on{background:#4361EE;color:#fff;border-color:#4361EE;}
.navBtn[data-nav="output"].on{background:#2DD4BF;color:#0a0f0a;border-color:#2DD4BF;}
.navBtn[data-nav="storyboard"].on{background:#8B5CF6;color:#fff;border-color:#8B5CF6;}
.navBtn[data-nav="aidirector"].on{background:#F97316;color:#fff;border-color:#F97316;}
.navBtn[data-nav="assets"].on{background:#EC4899;color:#fff;border-color:#EC4899;}
.assetTypeBtn{flex:1;padding:7px 10px;border-radius:6px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid #3f3f46;background:transparent;color:#71717a;transition:all .15s;text-align:center;}
.assetTypeBtn.on{border-color:#EC4899;background:#EC489922;color:#f472b6;}
.assetCard{background:#141714;border:1px solid #2a2e2a;border-radius:8px;padding:10px 12px;margin-bottom:8px;}
.assetTypeBadge{font-size:9px;font-weight:600;padding:2px 8px;border-radius:10px;text-transform:uppercase;letter-spacing:.03em;flex-shrink:0;}
.assetTypeBadge.character{background:#EC489922;color:#f472b6;}
.assetTypeBadge.product{background:#F59E0B22;color:#fbbf24;}
.assetTypeBadge.location{background:#14B8A622;color:#2dd4bf;}
.modeToggle{display:flex;background:#1a1d1a;border:1px solid #3f3f46;border-radius:8px;padding:3px;gap:3px;}
.modeBtn{padding:5px 14px;border-radius:5px;font-size:11px;font-weight:500;cursor:pointer;border:none;background:transparent;color:#71717a;font-family:"DM Sans",sans-serif;transition:all .2s;white-space:nowrap;}
.modeBtn.on{background:#84CC16;color:#0a0f0a;}
.outToggle{display:flex;background:#1a1d1a;border:1px solid #3f3f46;border-radius:7px;padding:3px;gap:3px;}
.outBtn{padding:5px 14px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;border:none;background:transparent;color:#71717a;font-family:"DM Sans",sans-serif;transition:all .2s;}
.outBtn.on{background:#2a2e2a;color:#e4e4e7;}
.viralBox{background:#141714;border:1px solid #7c3aed33;border-radius:8px;padding:12px;font-size:11px;color:#a1a1aa;line-height:1.6;}
.viralTag{background:#7c3aed22;color:#a78bfa;border:1px solid #7c3aed33;border-radius:4px;padding:2px 7px;font-size:10px;font-weight:500;display:inline-block;margin:2px;}
.spinner{display:inline-block;width:12px;height:12px;border:2px solid #3a3e3a;border-top-color:#84CC16;border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
<body>

<div style="position:sticky;top:0;z-index:50;background:#111412;border-bottom:1px solid #2a2e2a;padding:0 16px;">
  <div style="max-width:860px;margin:0 auto;height:50px;display:flex;align-items:center;gap:10px;">
    <div class="film" style="width:16px;flex-shrink:0;"></div>
    <span style="font-family:'Bebas Neue',sans-serif;font-size:21px;letter-spacing:.1em;color:#84CC16;">CINEAI<span style="color:#52525b;">HUB</span></span>
    <div class="film" style="width:16px;flex-shrink:0;"></div>
    <span class="bA" style="font-size:9px;">v11</span>
    <div style="flex:1;"></div>
    <div id="savedDot" style="font-size:10px;color:#3a3e3a;display:flex;align-items:center;gap:4px;transition:color .3s;">
      <svg width="7" height="7" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>Saved
    </div>
    <button class="btnG" style="font-size:11px;" onclick="doExport()" title="Export brand profile (Story Builder fields) as JSON">&#8595; Export Brand</button>
    <label class="btnG" style="font-size:11px;cursor:pointer;" title="Load a previously exported brand profile">&#8593; Load Brand<input type="file" accept=".json" style="display:none;" onchange="doImport(this)"></label>
    <button class="btnD" style="font-size:11px;" onclick="doReset()">Reset</button>
  </div>
</div>

<div style="max-width:860px;margin:0 auto;padding:16px;">

  <!-- Reset confirmation bar — inline, no browser confirm() -->
  <div id="resetBar" style="display:none;background:#7f1d1d22;border:1px solid #f8717133;border-radius:8px;padding:10px 14px;margin-bottom:10px;align-items:center;gap:10px;flex-wrap:wrap;">
    <span style="font-size:12px;color:#fca5a5;flex:1;">⚠️ Reset all data? This cannot be undone.</span>
    <button class="btnD" style="font-size:11px;" onclick="doResetConfirm()">Yes, reset everything</button>
    <button class="btnG" style="font-size:11px;" onclick="document.getElementById('resetBar').style.display='none'">Cancel</button>
  </div>
  <!-- Import success notice -->
  <div id="importSuccessBar" style="display:none;background:#16a34a22;border:1px solid #16a34a44;border-radius:8px;padding:10px 14px;margin-bottom:10px;align-items:center;gap:8px;">
    <span style="font-size:12px;color:#4ade80;">✓ Brand profile loaded — scenes and storyboard untouched. Ready for new content.</span>
  </div>

  <div id="nav">
    <button class="navBtn on" data-nav="story">✏️ Story Builder</button>
    <button class="navBtn" data-nav="scenes">🎬 Scene Editor</button>
    <button class="navBtn" data-nav="output">⚡ Output</button>
    <div style="width:2px;background:#52525b;height:24px;flex-shrink:0;align-self:center;border-radius:2px;"></div>
    <button class="navBtn" data-nav="storyboard">📋 Storyboard</button>
    <button class="navBtn" data-nav="aidirector">🎙️ AI Director Pro</button>
    <button class="navBtn" data-nav="assets">🎭 Assets</button>
  </div>

  <!-- ══ STORY BUILDER ══ -->
  <div id="sec-story" class="panel on">
    <div style="margin-bottom:16px;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.06em;color:#84CC16;">STORY BUILDER</div>
      <div style="font-size:12px;color:#52525b;">Define your project · build characters · generate script → paste to AI → import scenes</div>
    </div>

    <!-- Mode + Project Type -->
    <div class="card" style="margin-bottom:12px;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:12px;">
        <span class="bA">PROJECT TYPE</span>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:11px;color:#52525b;">Mode:</span>
          <div class="modeToggle">
            <button class="modeBtn on" id="modeReal" onclick="setMode('realistic',this)">&#127916; Realistic</button>
            <button class="modeBtn" id="modeAnim" onclick="setMode('animated',this)">&#127912; Animated</button>
          </div>
        </div>
      </div>
      <div id="ptGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:8px;"></div>
    </div>

    <!-- Core Settings -->
    <div class="card" style="margin-bottom:12px;">
      <div style="margin-bottom:10px;"><span class="bB">CORE SETTINGS</span></div>
      <div class="g3" style="margin-bottom:12px;">
        <div>
          <label class="lbl">Platform</label>
          <select class="inp" id="platform" onchange="save()">
            <option value="">Select...</option>
            <option>Instagram Reels (9:16)</option>
            <option>TikTok (9:16)</option>
            <option>YouTube Shorts (9:16)</option>
            <option>YouTube (16:9)</option>
            <option>Instagram Feed (4:5)</option>
            <option>Cinema (2.39:1)</option>
            <option>Short Film (16:9)</option>
            <option>No specific platform</option>
          </select>
        </div>
        <div>
          <label class="lbl">Genre</label>
          <select class="inp" id="genre" onchange="updateGenreDesc();save()">
            <option value="">Select...</option>
            <option>Talking Head / Interview</option>
            <option>Slice of Life</option><option>Drama</option><option>Romance</option>
            <option>Thriller / Suspense</option><option>Horror</option><option>Comedy</option>
            <option>Sci-Fi</option><option>Fantasy</option><option>Documentary</option>
            <option>Action</option><option>Music Video</option><option>Brand Commercial</option>
            <option>Experimental / Art Film</option>
          </select>
          <div id="genreDesc" style="font-size:10px;color:#52525b;margin-top:4px;min-height:14px;"></div>
        </div>
        <div>
          <label class="lbl">General Mood</label>
          <select class="inp" id="mood" onchange="updateMoodDesc();save()">
            <option value="">Select...</option>
            <option>Warm and Nostalgic</option><option>Dark and Moody</option>
            <option>Bright and Energetic</option><option>Calm and Contemplative</option>
            <option>Tense and Suspenseful</option><option>Romantic and Intimate</option>
            <option>Raw and Gritty</option><option>Dreamlike and Surreal</option>
            <option>Comedic and Playful</option><option>Epic and Grandiose</option>
            <option>Melancholic and Poetic</option><option>Bold and Confident</option>
          </select>
          <div id="moodDesc" style="font-size:10px;color:#52525b;margin-top:4px;min-height:14px;"></div>
        </div>
      </div>
      <div class="g2">
        <div id="visualStyleWrap">
          <label class="lbl">Visual Style <span style="color:#ef4444;font-size:9px;">injected first into ALL prompts</span></label>
          <select class="inp" id="visualStyle" onchange="save()">
            <option value="">Select style...</option>
          </select>
        </div>
        <div>
          <label class="lbl">Emotional Core</label>
          <select class="inp" id="emotionalCore" onchange="updateEmotionalCoreDesc();save()">
            <option value="">Select...</option>
            <option>Longing / Nostalgia</option><option>Joy / Euphoria</option>
            <option>Grief / Loss</option><option>Love / Connection</option>
            <option>Anxiety / Unease</option><option>Wonder / Discovery</option>
            <option>Isolation / Loneliness</option><option>Hope / Rebirth</option>
            <option>Anger / Frustration</option><option>Peace / Acceptance</option>
            <option>Identity Crisis</option><option>Bittersweet</option>
          </select>
          <div id="emotionalCoreDesc" style="font-size:10px;color:#52525b;margin-top:4px;min-height:14px;"></div>
        </div>
      </div>
      <div class="g2" style="margin-top:10px;">
        <div>
          <label class="lbl">Content Intent <span style="color:#f472b6;font-size:9px;">shapes visual grammar for your goal</span></label>
          <select class="inp" id="intent" onchange="updateIntentDesc();save()">
            <option value="">Select intent...</option>
            <option value="branding">Branding / Brand Film</option>
            <option value="ugc_review">Review / UGC</option>
            <option value="education">Education / Explainer</option>
            <option value="storytelling">Storytelling / Narrative</option>
            <option value="promo">Hype / Promo</option>
            <option value="testimonial">Testimonial / Talking Head</option>
          </select>
          <div id="intentDesc" style="font-size:10px;color:#52525b;margin-top:4px;min-height:14px;"></div>
        </div>
        <div>
          <label class="lbl">Texture Finish <span style="color:#f472b6;font-size:9px;">how raw or polished the capture feels</span></label>
          <select class="inp" id="texFinish" onchange="save()">
            <option value="">Auto — follows Content Intent</option>
            <option value="raw">Raw — celluloid imperfection, exposure sacrifice, optical defects</option>
            <option value="balanced">Balanced — restrained texture, subtle artifacts</option>
            <option value="clean">Clean — commercial polish, zero artifacts</option>
          </select>
          <div style="font-size:10px;color:#52525b;margin-top:4px;min-height:14px;">Drives EXPOSURE and OPTICS layers in every prompt</div>
        </div>
      </div>
      <!-- Music Video panel — visible only when project type = Music Video -->
      <div id="mvPanel" style="display:none;margin-top:12px;padding:12px;background:#141714;border:1px solid #f472b633;border-radius:8px;">
        <div style="font-size:12px;font-weight:600;color:#f472b6;margin-bottom:10px;">&#127925; Music Video Treatment</div>
        <div class="g2">
          <div>
            <label class="lbl">MV Treatment <span style="color:#f472b6;font-size:9px;">replaces director styles for MV</span></label>
            <select class="inp" id="mvStyle" onchange="save()">
              <option value="">Select treatment...</option>
              <option value="performance_raw">Performance Raw — intimate single-take energy</option>
              <option value="choreo_cinematic">Choreography Cinematic — dance-first, precise blocking</option>
              <option value="visual_concept">Visual Concept — surreal artistic imagery</option>
              <option value="street_lifestyle">Street / Lifestyle — golden hour, fashion-forward</option>
              <option value="hype_energy">Hype / Energy — bold, aggressive, rapid</option>
            </select>
          </div>
          <div>
            <label class="lbl">Song Tempo / Energy</label>
            <select class="inp" id="mvTempo" onchange="save()">
              <option value="">Select tempo...</option>
              <option value="slow_ballad">Slow Ballad — long emotional takes</option>
              <option value="mid_tempo">Mid-Tempo — grooving steady rhythm</option>
              <option value="upbeat">Upbeat — energetic driving pace</option>
              <option value="high_energy">High Energy — rapid aggressive cuts</option>
            </select>
          </div>
        </div>
        <div class="g2" style="margin-top:10px;">
          <div>
            <label class="lbl">Genre Feel <span style="color:#52525b;font-size:9px;">shapes visual vocabulary</span></label>
            <input class="inp" id="mvGenre" placeholder="e.g. R&B, pop, hip-hop, indie rock, EDM..." onchange="save()"/>
          </div>
          <div>
            <label class="lbl">Song Mood Arc <span style="color:#52525b;font-size:9px;">section-by-section emotional shape</span></label>
            <input class="inp" id="mvArc" placeholder="e.g. melancholic verses → explosive chorus → quiet bridge → euphoric finale" onchange="save()"/>
          </div>
        </div>
        <div style="font-size:10px;color:#52525b;margin-top:8px;line-height:1.4;">Story Builder will structure scenes around song sections (verse/chorus/bridge) instead of plot beats. Lip-sync performance scenes are marked automatically — paste your own track in the AI platform; no lyrics are generated here.</div>
      </div>
    </div>

    <!-- Style Reference -->
    <div class="card" style="margin-bottom:12px;">
      <div class="optHdr" onclick="togOpt('styleref')">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:13px;font-weight:600;color:#e4e4e7;">Visual Style Reference</span>
          <span class="bA" style="font-size:9px;">OPTIONAL</span>
          <span style="font-size:10px;color:#52525b;">Mood board, visual guide, color palette, brand imagery</span>
        </div>
        <svg id="stylerefChev" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#52525b;transition:transform .2s;flex-shrink:0;"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="optBody" id="stylerefBody">
        <div style="background:#141714;border:1px solid #84CC1633;border-radius:6px;padding:10px;font-size:11px;color:#a1a1aa;margin-bottom:10px;line-height:1.5;">
          &#9888; <strong style="color:#a3e635;">For visual assets:</strong> mood boards, color palette images, brand visual guides, reference photos. Upload image to ChatGPT/Claude/Gemini with the prompt below → paste AI response here. Injected into all image + video prompts as visual anchor. <strong style="color:#a3e635;">Note: Shot type per scene still overrides composition — this only affects color, texture, atmosphere.</strong><br><br>
          <span style="color:#52525b;">Have a brand guidelines PDF with text (audience, tone, messaging)? Use Project DNA below instead.</span>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
          <button class="btnG" style="font-size:11px;" onclick="genStylePrompt()">&#128247; Generate Style Extraction Prompt</button>
          <button class="cpBtn" id="styleExtCpBtn" style="position:static;display:none;" onclick="cpEl('styleExtPrompt',this)">Copy Prompt</button>
