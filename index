function styleAnch(){
  var p=S.proj,pts=[];
  var rs=resolveStyle();
  var cvs=document.getElementById('customVisualStyle');
  var customStyle=cvs?cvs.value.trim():'';
  if(customStyle){
    // Short custom text that merely NAMES a known style ("wes anderson vibe") still needs the
    // dictionary translation — a director's name is a weak token. But LONG descriptive text
    // (typically a style-reference extraction) is the HIGHEST AUTHORITY: its grade is never
    // replaced, even when it contains dictionary trigger words like "analog" or "35mm".
    // STYLE_DICT still contributes comp (slot 1.5), formal flag, rig and medium either way.
    if(rs&&customStyle.length<60)pts.push(rs.grade);
    else pts.push(customStyle);
  } else if(rs){
    // Dropdown-recognized style — replace the weak raw token with physical grammar (grade only;
    // comp lives exclusively at bldImg slot 1.5).
    pts.push(rs.grade);
  } else if(p.visualStyle){
    pts.push(p.visualStyle);
  }
  var ie=intentEntry();
  if(ie)pts.push(ie.img);
  if(p.mood)pts.push(p.mood+' mood and atmosphere');
  if(p.emotionalCore)pts.push('emotional undercurrent of '+p.emotionalCore);
  return pts.join('. ');
}

