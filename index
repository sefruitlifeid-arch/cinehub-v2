  var list=S.aiDirector.cinema.savedPrompts.slice().sort(function(a,b){return b.createdAt-a.createdAt;});
  if(!list.length){box.innerHTML='<div style="text-align:center;padding:20px 12px;color:#52525b;font-size:12px;">No saved prompts yet.</div>';return;}
  box.innerHTML=list.map(function(p){
    var meta=[p.sceneTitle,p.cinemaModeLabel,p.runtime].filter(Boolean).join(' · ');
    var fullId='cfull_'+p.id.toString().replace('.','');
    return '<div class="card" style="margin-bottom:10px;">'+
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px;">'+
        '<span style="font-size:11px;color:#a1a1aa;">'+(meta||'Standalone')+'</span>'+
        '<button class="btnG" style="font-size:10px;padding:3px 8px;" onclick="removeCinemaSavedPrompt('+p.id+')">&#10005; Remove</button>'+
      '</div>'+
      '<div style="font-size:10px;color:#52525b;margin-bottom:8px;">&#127909; This is a VIDEO prompt — paste the full text below into Seedance/Higgsfield.</div>'+
