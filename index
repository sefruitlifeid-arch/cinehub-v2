function addScene(){
  if(S.scenes.length>=20){alert('Max 20 scenes');return;}
  S.scenes.push({
    id:Date.now(),title:'',script:'',dialog:'',showDialog:false,
    location:'',time:'',beat:'',mood:'',
    brollOnly:false,collapsed:false,
    shotType:'',shotNotes:'',movement:'',movementNotes:'',
    position:null,progress:{generated:false},
  });
  save();renderScenes();
}
function removeScene(id){S.scenes=S.scenes.filter(function(s){return s.id!==id;});S.assetLinks=(S.assetLinks||[]).filter(function(l){return l.sceneId!==id;});save();renderScenes();}
function togSc(id){var sc=S.scenes.find(function(s){return s.id===id;});if(sc){sc.collapsed=!sc.collapsed;save();renderScenes();}}
function updSc(id,field,val){var sc=S.scenes.find(function(s){return s.id===id;});if(sc){sc[field]=val;save();}}

function mkDD(scId,field,opts,ph){
  var sc=S.scenes.find(function(s){return s.id===scId;});var val=sc?sc[field]:'';
  var h='<select class="inp" data-scid="'+scId+'" data-scf="'+field+'"><option value="">'+ph+'</option>';
  opts.forEach(function(o){h+='<option'+(o===val?' selected':'')+'>'+o+'</option>';});
  return h+'</select>';
}

function rChips(scId,field){
  var sc=S.scenes.find(function(s){return s.id===scId;});if(!sc)return'';
  var opts=CHIP[field]||[],vals=sc[field]||[];
  var h='<div class="cg">';
  opts.forEach(function(opt){
    var on=vals.indexOf(opt)>-1;
    h+='<div class="chip'+(on?' on':'')+'" data-scid="'+scId+'" data-scf="'+field+'" data-val="'+opt.replace(/"/g,'&quot;')+'">'+opt+'</div>';
  });
  return h+'</div>';
}

// ═══ ASSET LIBRARY ═══ (separate from S.chars — covers Character/Product/Location, stores only
// a text description, never an image. "Import from Character" is a one-way name copy from S.chars,
// it does not keep the two in sync afterward.)
var ASSET_FORM_TYPE='character';

var ASSET_ANALYZE_INSTRUCTIONS={
  character:'Analyze this character\'s visual appearance and reply in EXACTLY this two-line labeled format:\nDESCRIPTION: [1-2 lean sentences, prompt-ready language — physical traits, hair, outfit, distinguishing features. No actions, poses, or scene context.]\nIDENTITY TOKEN: [max 25 words — the compressed visual essence: age/ethnicity if visible, hair, skin, 2-3 most distinctive features, core wardrobe. This locks identity across video frames, so choose only what makes this person instantly recognizable.]',
  product:'Describe this product\'s visual appearance in 1-2 lean sentences, prompt-ready language. Cover: shape, material, color, key design details, branding/logo if visible. Do not include placement or context — only visual identity that stays consistent across different scenes.',
  location:'Describe this location\'s visual appearance in 1-2 lean sentences, prompt-ready language. Cover: architecture/setting type, color palette, lighting mood, distinguishing visual elements. Do not include characters or actions — only visual identity that stays consistent across different scenes.'
};

function toggleAssetForm(){
  var form=document.getElementById('assetForm');
  if(!form)return;
  var opening=form.style.display==='none'||!form.style.display;
  form.style.display=opening?'block':'none';
  if(opening){
    ASSET_FORM_TYPE='character';
    document.querySelectorAll('.assetTypeBtn').forEach(function(b){b.classList.remove('on');});
    var firstBtn=document.querySelector('.assetTypeBtn[data-assettype="character"]');
    if(firstBtn)firstBtn.classList.add('on');
    document.getElementById('assetNameInput').value='';
    document.getElementById('assetDescInput').value='';
    var ti=document.getElementById('assetTokenInput');if(ti)ti.value='';
    var ib=document.getElementById('assetInstructionBox');if(ib){ib.value='';ib.style.display='none';}
    var icb=document.getElementById('assetInstructionCpBtn');if(icb)icb.style.display='none';
    populateAssetImportCharSelect();
  }
}

function populateAssetImportCharSelect(){
  var sel=document.getElementById('assetImportCharSelect');
  if(!sel)return;
  sel.innerHTML='<option value="">Import from Character...</option>';
  (S.chars||[]).forEach(function(ch){
    if(!ch.name)return;
    var o=document.createElement('option');o.value=ch.name;o.textContent=ch.name;sel.appendChild(o);
  });
}

function genAssetAnalyzeInstruction(){
  var instruction=ASSET_ANALYZE_INSTRUCTIONS[ASSET_FORM_TYPE]||ASSET_ANALYZE_INSTRUCTIONS.character;
  var box=document.getElementById('assetInstructionBox');
  if(box){box.value=instruction;box.style.display='block';}
  var btn=document.getElementById('assetInstructionCpBtn');
  if(btn){btn.style.display='inline-flex';doCopy(instruction,btn);}
}

function saveNewAsset(){
  var name=(document.getElementById('assetNameInput').value||'').trim();
  var desc=(document.getElementById('assetDescInput').value||'').trim();
  var tokEl=document.getElementById('assetTokenInput');
  var token=(tokEl&&tokEl.value||'').trim();
  // Auto-parse labeled AI output: "DESCRIPTION: ..." / "IDENTITY TOKEN: ..."
  var m=desc.match(/IDENTITY\s*TOKEN\s*:\s*([\s\S]+)$/i);
  if(m){
    if(!token)token=m[1].trim().split('\n')[0].trim();
    desc=desc.replace(/IDENTITY\s*TOKEN\s*:[\s\S]+$/i,'').replace(/^DESCRIPTION\s*:\s*/i,'').trim();
  } else {
    desc=desc.replace(/^DESCRIPTION\s*:\s*/i,'').trim();
  }
  if(!name){alert('Please enter a name for this asset.');return;}
  S.assets=S.assets||[];
  S.assets.push({id:Date.now()+Math.random(),name:name,type:ASSET_FORM_TYPE,description:desc,identityToken:token,position:null});
  save();
  toggleAssetForm();
  renderAssetLibrary();
  renderScenes();
}

function removeAsset(assetId){
  if(!confirm('Delete this asset? Any links to scenes will also be removed.'))return;
  S.assets=(S.assets||[]).filter(function(a){return a.id!==assetId;});
  S.assetLinks=(S.assetLinks||[]).filter(function(l){return l.assetId!==assetId;});
  save();
  renderAssetLibrary();
  renderScenes();
}

function updAssetField(assetId,field,val){
  var a=(S.assets||[]).find(function(x){return x.id===assetId;});
  if(a){a[field]=val;save();}
}

function renderAssetLibrary(){
  var list=document.getElementById('assetList');
  var empty=document.getElementById('assetEmpty');
  if(!list)return;
  var assets=S.assets||[];
  if(!assets.length){
    list.innerHTML='';
    if(empty)empty.style.display='block';
    return;
  }
  if(empty)empty.style.display='none';
  var h='';
  assets.forEach(function(a){
    var linkCount=(S.assetLinks||[]).filter(function(l){return l.assetId===a.id;}).length;
    h+='<div class="assetCard">'+
      '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">'+
        '<span class="assetTypeBadge '+a.type+'">'+a.type+'</span>'+
        '<span style="font-size:12px;color:#e4e4e7;flex:1;font-weight:500;">'+escapeHtml(a.name||'Untitled')+'</span>'+
        (linkCount?'<span style="font-size:9px;color:#52525b;">&#128279; '+linkCount+' scene'+(linkCount>1?'s':'')+'</span>':'')+
        '<button class="btnD" style="font-size:10px;padding:3px 8px;" data-rmasset="'+a.id+'">&times;</button>'+
      '</div>'+
      '<div style="font-size:11px;color:#a1a1aa;line-height:1.5;">'+(a.description?escapeHtml(a.description):'<span style="color:#52525b;font-style:italic;">No description yet.</span>')+'</div>'+
      (a.identityToken?'<div style="font-size:10px;color:#84cc16;line-height:1.4;margin-top:4px;font-family:JetBrains Mono;">&#128274; '+escapeHtml(a.identityToken)+'</div>':'')+
