function parseImport(){
  var raw=document.getElementById('importField').value.trim();
  if(!raw){alert('Nothing to import');return;}
  var lines=raw.split('\n').filter(function(l){return l.trim().toUpperCase().match(/^SCENE_/);});
  if(!lines.length){alert('No SCENE_ lines found.');return;}
  function gf(line,key){var rx=new RegExp('\\|\\s*'+key+':\\s*([^|]+)','i');var m=line.match(rx);return m?m[1].trim():'';}
  var parsed=lines.map(function(line,idx){
    var dlgVal=gf(line,'DIALOG');var hasDlgVal=dlgVal&&dlgVal.trim()&&dlgVal.trim().toUpperCase()!=='NONE';
    return{
      id:Date.now()+idx,title:gf(line,'TITLE'),script:gf(line,'ACTION'),
      dialog:dlgVal,showDialog:!!hasDlgVal,
      location:gf(line,'LOCATION'),time:gf(line,'TIME'),beat:gf(line,'BEAT'),mood:gf(line,'MOOD'),
      brollOnly:false,collapsed:false,
      // NEW: separate shot type and movement fields
      shotType:'',shotNotes:'',movement:'',movementNotes:'',
      // kept for backward compat
      angle:[],lighting:[],lightQuality:[],animEnergy:[],
      cameraBody:'',lensType:'',focalLength:'',aperture:'',visualLook:'',
      artStyle:'',colorPaletteMood:'',composition:''
    };
