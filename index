function parseBrandResponse(){
  var raw=document.getElementById('brandPasteField').value.trim();
  if(!raw){alert('Paste AI response first');return;}
  function gf(k){var rx=new RegExp('^'+k+':\\s*(.+)','im');var m=raw.match(rx);return m?m[1].trim():'';}
  var map={dnaTitle:'TITLE',dnaName:'BRAND_NAME',dnaCoreMessage:'CORE_MESSAGE',dnaPainPoint:'PAIN_POINT',dnaAudience:'TARGET_AUDIENCE',dnaTone:'TONE',dnaInstructions:'CUSTOM_INSTRUCTIONS'};
  var filled=0;
  Object.keys(map).forEach(function(fieldId){
    var val=gf(map[fieldId]);
    if(val){var el=document.getElementById(fieldId);if(el){el.value=val;filled++;}}
  });
  var vsVal=gf('VISUAL_STYLE');
  if(vsVal){var cvs=document.getElementById('customVisualStyle');if(cvs){cvs.value=vsVal;filled++;}}
  save();
  alert('Auto-filled '+filled+' fields from AI response.');
}

// ═══ COPY HELPERS ═══
function doCopy(text,btn){
  function done(){if(btn){btn.textContent='Copied!';btn.classList.add('ok');setTimeout(function(){btn.textContent=btn.getAttribute('data-cpel')?'Copy':'Copy';btn.classList.remove('ok');},2000);}}
  if(navigator.clipboard&&window.isSecureContext){navigator.clipboard.writeText(text).then(done).catch(function(){fbCopy(text);done();});}
  else{fbCopy(text);done();}
}
function fbCopy(t){var el=document.createElement('textarea');el.value=t;el.style.cssText='position:fixed;top:-999px;opacity:0;';document.body.appendChild(el);el.focus();el.select();try{document.execCommand('copy');}catch(e){}document.body.removeChild(el);}
function cpEl(id,btn){
  var el=document.getElementById(id);
  var text=el?(el.tagName==='TEXTAREA'||el.tagName==='INPUT'?el.value:el.innerText.replace(/\nCopy$|\nCopied!$/g,'').trim()):'';
  doCopy(text,btn);
}

