// Migrate old panel shape ({visual, function:string, caption:string}) to new schema
// ({framing, movementGuide:{move,speed,subjectLock,stability,durationHint}, caption:{headline,subtext}, function:string freeform})
function migratePanelSchema(p){
  var base={id:p.id||(Date.now()+Math.random()),beat:p.beat||'',framing:'',function:(typeof p.function==='string'?p.function:''),
    movementGuide:{move:'',speed:'',subjectLock:'',stability:'',durationHint:''},
    caption:{headline:'',subtext:''},captionWeight:'none'};
  // old field 'visual' (free text) becomes the beat/visual reference if beat is empty
  if(p.visual&&!base.beat)base.beat=p.visual;
  if(p.framing)base.framing=p.framing;
  if(p.movementGuide&&typeof p.movementGuide==='object')base.movementGuide=Object.assign(base.movementGuide,p.movementGuide);
  if(p.caption&&typeof p.caption==='object')base.caption=Object.assign(base.caption,p.caption);
  else if(typeof p.caption==='string'&&p.caption)base.caption.headline=p.caption;
  if(p.captionWeight)base.captionWeight=p.captionWeight;
  return base;
}
