// GPT Image storyboard grid prompt — explicit anti-generic instructions, uses FRAMING only (movement never affects the image)
function getDirectorPersona(){
  var sb=S.storyboard;
  var tmpl=NARRATIVE_TEMPLATES.find(function(t){return t.id===sb.narrativeTemplate;});
  return (tmpl&&tmpl.persona)?tmpl.persona:'a professional director and storyboard artist';
}

// Grid layout adapts to the selected output aspect ratio — a 3-column grid suits landscape,
// but becomes awkward (panels absurdly narrow) on a tall vertical canvas, so column count adapts.
function getGridLayout(n,ratio){
  if(ratio==='9:16'){
    var cols916=n<=4?1:2;
    return{cols:cols916,rows:Math.ceil(n/cols916),sheetDesc:'9:16 vertical storyboard sheet'};
  }
  if(ratio==='1:1'){
    var cols11=Math.ceil(Math.sqrt(n));
    return{cols:cols11,rows:Math.ceil(n/cols11),sheetDesc:'1:1 square storyboard sheet'};
  }
  if(ratio==='4:5'){
    var cols45=n<=6?2:3;
    return{cols:cols45,rows:Math.ceil(n/cols45),sheetDesc:'4:5 portrait storyboard sheet'};
  }
  // default 16:9
  return{cols:3,rows:Math.ceil(n/3),sheetDesc:'16:9 landscape storyboard sheet'};
}

// Shared panel structure + footer/caption instructions, used by both realistic and animated grid prompt builders
function bldStoryboardPanelStructure(useCaption,n){
  var h='PANEL STRUCTURE — each panel has two clearly separated zones, like a real production storyboard sheet, NOT like video subtitles overlaid on the image:\n';
  h+='1. Main image area — the full frame, no text crammed against the edges.\n';
  h+='2. A dedicated footer annotation strip beneath the image area — a distinct band with its own background (e.g. solid white or light neutral), visually separated from the image by a clear border or edge. Annotation text lives inside this strip, never overlaid directly on top of the image.\n\n';
  if(useCaption){
    h+='IN-IMAGE CAPTION SYSTEM (this is a fixed design system applied consistently — NOT a fresh layout decision per panel):\n';
    h+='- Headline (used only on "hero" panels): bold, large handwritten-style text, fixed position in the upper area of the image, strong color contrast against the background.\n';
    h+='- Support note (used only on "support" panels): smaller, quieter handwritten text, fixed position, lighter visual weight than a headline — should read as a small aside, not a second headline.\n';
    h+='- "none"-weight panels carry NO in-image text at all — let the image speak for itself.\n';
    h+='- CRITICAL — do not give every panel a large headline. Vary the treatment by the weight assigned to each panel below. The result should alternate between strong moments and quiet moments, not shout uniformly across all '+n+' panels.\n\n';
  } else {
    h+='No in-image text/captions — keep the image area clean, text-free.\n\n';
  }
  h+='FOOTER ANNOTATION — every panel, regardless of caption weight, gets a short factual line in the footer strip describing what is happening (this is separate from any in-image caption and is always plain, small, neutral text — a production note, not creative copy).\n\n';
  return h;
}

function bldStoryboardPanelList(panels,useCaption){
  var h='';
  panels.forEach(function(p,i){
    var fLabel=p.function?'['+p.function+'] ':'';
    var framingDesc=p.framing?(p.framing+(SHOT_COMPOSITION&&SHOT_COMPOSITION[p.framing]?' — '+SHOT_COMPOSITION[p.framing]:'')):'';
    var weight=p.captionWeight||'none';
    h+=(i+1)+'. '+fLabel+(framingDesc?'['+framingDesc+'] ':'')+(p.beat||'(describe panel)')+' — footer: "'+(p.beat||'panel '+(i+1))+'"';
    if(useCaption&&weight!=='none'&&p.caption&&(p.caption.headline||p.caption.subtext)){
      h+=weight==='hero'?(' — HERO headline: "'+(p.caption.headline||'')+'"'):(' — support note: "'+(p.caption.headline||p.caption.subtext||'')+'"');
    } else if(useCaption){
      h+=' — no in-image text (visual only)';
    }
    h+='\n';
  });
  return h;
}

// REALISTIC mode — photographic, injects PHOTOREALISM_TECHNICAL + PHOTOREALISM_AESTHETIC (unless a custom Visual
