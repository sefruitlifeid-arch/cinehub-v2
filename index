// Import: loads Story Builder fields only — scenes, storyboard, AI Director untouched
function doImport(input){
  var file=input.files[0];if(!file)return;
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var d=JSON.parse(e.target.result);
      if(d.proj)S.proj=Object.assign(S.proj,d.proj);
      if(d.dna)S.dna=Object.assign(S.dna,d.dna);
      if(d.chars)S.chars=d.chars;
      if(d.viralNotes!==undefined)S.viralNotes=d.viralNotes;
      // restore custom visual style textarea
      var cvs=document.getElementById('customVisualStyle');
      if(cvs&&d.customVisualStyle!==undefined)cvs.value=d.customVisualStyle;
      save();
      renderPT();populateStyleDropdown();renderChars();applyForm();initCoreSettingDescs();
      var vn=document.getElementById('viralNotes');if(vn)vn.value=S.viralNotes||'';
      goTo('story');
      // show success notice
      var bar=document.getElementById('importSuccessBar');
      if(bar){bar.style.display='flex';setTimeout(function(){bar.style.display='none';},3000);}
    }catch(err){alert('Could not load file — make sure it\'s a CineAI Hub brand export.');}
    input.value='';
  };
  reader.readAsText(file);
}
