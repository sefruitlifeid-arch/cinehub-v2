// ─── SANITIZATION LAYER ───

// Phrase-level dedup: split on commas, drop case-insensitive repeats, rejoin.
function dedupPhrases(str){
  if(!str)return'';
  var seen={},out=[];
  str.split(',').forEach(function(p){
    var t=p.trim();if(!t)return;
    var k=t.toLowerCase();
    if(!seen[k]){seen[k]=1;out.push(t);}
  });
  return out.join(', ');
}

// First-N-words compression (identityToken fallback).
function compressWords(str,n){
  if(!str)return'';
  var w=str.trim().split(/\s+/);
  return w.slice(0,n).join(' ').replace(/[,.;:\s]+$/,'');
}

// Punctuation-safe prose join: strips trailing punctuation per fragment,
// joins with '. ', collapses double dots / spaces / dash collisions.
function joinProse(parts){
  var frags=parts.filter(Boolean).map(function(p){return String(p).trim().replace(/[.,;\s]+$/,'');}).filter(Boolean);
  return frags.join('. ')
    .replace(/\.{2,}/g,'.')
    .replace(/\s{2,}/g,' ')
    .replace(/\s—\s\./g,'.')
    .replace(/:\s*\./g,'.');
}

// Central brand-speak sanitizer for S.dna.instructions — one implementation
// for ALL builders. Strips buzzwords, emoji, hashtags; caps at 2 sentences / 30 words.
var SLOP_WORDS=/\b(viral|engaging|eye-?catching|stunning|high[- ]quality|masterpiece|trending|next[- ]level|scroll[- ]stopping|breathtaking|epic|amazing|awesome)\b/gi;
function cleanInstr(){
  var raw=(S.dna&&S.dna.instructions)?S.dna.instructions:'';
  if(!raw.trim())return'';
  var t=raw.replace(/#[\w]+/g,'')
    .replace(/[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]/gu,'')
    .replace(/\s{2,}/g,' ').trim();
  if(!t)return'';
  // Drop WHOLE sentences containing brand-speak (word-level stripping leaves
  // grammatical shrapnel like "Make it and !!"). Keep only clean sentences.
  var kept=t.split(/(?<=[.!?])\s+/).filter(function(s){
    SLOP_WORDS.lastIndex=0;
    return s.trim()&&!SLOP_WORDS.test(s)&&/[a-zA-Z]/.test(s);
  });
  if(!kept.length)return'';
  var sentences=kept.slice(0,2).join(' ');
  var w=sentences.split(/\s+/);
  if(w.length>30)sentences=w.slice(0,30).join(' ');
  return sentences.replace(/^[,.;\s]+|[,;\s]+$/g,'');
}

// ─── LOOK-TOKEN RESOLVER ───
// target: 'img' (full emulsion physics) | 'vid' (motion-persistence subset).
// Looks up raw stored values (NOT cV-stripped). Unknown values pass through
// unchanged — never silently dropped. Output is phrase-deduped.
// ─── EFFECTIVE RIG (style default, user dropdown override) ───
// A recognized style carries its canonical camera package (rig). Empty scene fields
// fall back to the rig; anything the user picked manually always wins.
function effRig(sc){
  var rs=resolveStyle();
  var rig=(rs&&rs.rig)||{};
  // Shot-on-Phone project type supplies the phone package as the fallback rig
  // (style rig still wins over this fallback; manual scene fields win over everything).
  if(S.proj.type==='phoneshoot'&&!rig.cam)rig={cam:'iPhone 15 Pro Cinematic',lens:'Prime — Fixed focal, sharp',focal:'28mm — Street natural',aperture:'f/1.8 — Sharp subject soft BG',look:rig.look||''};
  return{
    cameraBody:sc.cameraBody||rig.cam||'',
    lensType:sc.lensType||rig.lens||'',
    focalLength:sc.focalLength||rig.focal||'',
    aperture:sc.aperture||rig.aperture||'',
    visualLook:sc.visualLook||rig.look||''
  };
}

// ─── CAPTURE MEDIUM RESOLVER ───
// film / digital / phone — each medium fails differently, so its imperfections must be
// the correct species (film: halation+crush; digital: rolloff; phone: HDR+clipping+noise).
function mediumFor(sc){
  var r=effRig(sc);
  if(/iphone|gopro|phone/i.test(r.cameraBody))return'phone';
  // Shot-on-Phone project type forces the phone pipeline end-to-end, UNLESS the user
  // manually picked a non-phone camera body (explicit dropdown choice always wins).
  if(S.proj.type==='phoneshoot'&&!sc.cameraBody)return'phone';
  var rs=resolveStyle();
  if(rs&&rs.medium)return rs.medium;
  if(/kodak|fuji|super 8|vision3|velvia|400h|b&w/i.test(r.visualLook))return'film';
  return'digital';
}

// ─── TEXTURE FINISH LEVEL ───
// raw / balanced / clean. Auto follows Content Intent (story decides how imperfect the
// capture should feel); manual dropdown overrides.
function finishLevel(){
  var t=S.proj.texFinish;
  if(t)return t;
  if(S.proj.type==='phoneshoot')return'raw';
  var map={ugc_review:'raw',storytelling:'raw',promo:'balanced',education:'balanced',testimonial:'balanced',branding:'clean'};
  return map[S.proj.intent]||'balanced';
}

// ─── EXPOSURE DECISION ───
// Real cinematography chooses what to sacrifice; AI training bias balances everything.
// Causal language forces the model to simulate the consequence of a single exposure choice.
function exposureDecision(sc){
  if(finishLevel()==='clean')return'';
  var med=mediumFor(sc);
  var env=((sc.time||'')+' '+(sc.location||'')+' '+arrS(sc.lighting)).toLowerCase();
  var night=/night|neon|low key|moody|dark|chiaroscuro/.test(env);
  if(med==='phone')return'computational Smart HDR exposure — lifted shadows, balanced tones, slightly flat but punchy, the honest phone-camera look';
  if(med==='film'){
    return night
      ?'exposed for the highlights — neon and practicals hold their color while shadows crush to true black with no lifted detail'
      :'exposed for the subject\'s skin — bright windows and sky allowed to blow out to clean white, shadows fall toward true black, one decisive exposure choice, never evenly balanced';
  }
  return night
    ?'exposed to protect the highlights, shadows crushed while retaining a hint of detail, deliberate contrast'
    :'exposed for skin tones with gentle digital highlight rolloff, deliberate unbalanced contrast';
}

// ─── SCENE-MOTIVATED OPTICAL ARTIFACTS ───
// Real defects need physical causes present in the scene (bright source → halation;
// haze → beams). Budget-capped: stacking every defect reads as a fake filter.
function opticArtifacts(sc,tier){
  var fin=finishLevel();
  if(fin==='clean')return'';
  var med=mediumFor(sc),r=effRig(sc);
  var lit=arrS(sc.lighting).toLowerCase()+' '+arrS(sc.lightQuality).toLowerCase();
  var env=((sc.location||'')+' '+(sc.time||'')).toLowerCase();
  var bright=/window|sun|golden|backlit|practical|neon|lamp|noon|day|sky|morning|afternoon/.test(lit+' '+env);
  var hardSide=/golden|backlit|window|sun|hard|chiaroscuro|low key|split|rim|dappled/.test(lit+' '+env);
  var lens=(r.lensType||'').toLowerCase();
  var a=[];
  if(med==='phone'){
    a.push('slight over-sharpening with high micro-contrast');
    a.push('fine digital chroma noise in the shadow areas');
    if(bright)a.push('abrupt highlight clipping where the sensor runs out');
    if(/neon|night/.test(env+' '+lit))a.push('small green dot lens flare from the strong lights');
  } else if(med==='film'){
    if(bright)a.push('warm orange-red halation bleeding around the bright light sources');
    if(hardSide)a.push('thin atmospheric haze rendering the hard light as visible shafts, dust caught in the beam');
    if(fin==='raw')a.push('1/48 shutter feel — hands and hair in micro-motion softly blurred');
    if(lens.indexOf('anamorphic')>-1)a.push('horizontal anamorphic flare streak, oval bokeh falloff');
    else if(lens.indexOf('vintage')>-1)a.push('gentle chromatic fringing on high-contrast edges, soft veiling glare lifting the blacks near the light source');
  } else {
    if(bright)a.push('controlled specular bloom with gentle highlight rolloff');
    if(lens.indexOf('anamorphic')>-1)a.push('restrained horizontal anamorphic flare, oval bokeh');
    else if(lens.indexOf('vintage')>-1)a.push('subtle chromatic fringing on contrast edges');
    if(hardSide)a.push('light atmospheric haze giving natural depth separation');
    if(fin==='raw')a.push('180-degree shutter motion feel on any movement');
  }
  var budget=tier==='kling'?2:(fin==='raw'?3:2);
  return a.slice(0,budget).join('; ');
}

// ─── FILMIC OPTICS (depth + lens softness) ───
// The real-camera tells the references share are OPTICAL, not skin-surface: shallow depth with
// genuine focus falloff, layered depth planes, gentle lens softness (NOT clinical sharpness),
// and natural motion blur. This operates at the FRAME level and never touches skin detail —
// the "too sharp / too clear / too perfect" fix without over-texturing faces. Aperture- and
// shot-aware so it never contradicts the deep-focus / bokeh negatives.
function filmicOptics(sc){
  var fin=finishLevel();
  var er=effRig(sc);
  var m=(er.aperture||'').match(/f\/(\d+(?:\.\d+)?)/i);
  var fn=m?parseFloat(m[1]):0; // 0 = unset
  var wideShot=/^(WS|Extreme Wide|FS)$/.test(sc.shotType||'');
  var parts=[];
  // Depth of field — shot-type first (a wide landscape must not get creamy bokeh), then aperture.
  if(wideShot||fn>5.6){
    parts.push('deep focus carried by real atmospheric perspective — haze and air density softening, desaturating and lowering the contrast of the distant planes, layered depth between foreground, subject and background');
  } else if(fn===0||fn<=2.8){
    parts.push('shallow depth of field, the subject in crisp focus while the background melts into soft creamy separation with natural focus falloff between clearly layered depth planes');
  } else {
    parts.push('moderate depth of field, the subject cleanly separated from a gently softened background across layered depth planes');
  }
  // Global lens softness — the direct antidote to clinical over-sharpness. Skipped only on a
  // deliberate CLEAN finish (commercial polish intentionally wants crispness).
  if(fin!=='clean')parts.push('organic optical rendering rather than clinical digital sharpness — a gentle lens softness and micro-contrast rolloff that reads as captured through real glass, edges easing off toward the frame corners');
  // Motion blur — only where the shot actually moves, and only on the balanced finish (raw already
  // gets shutter feel from opticArtifacts; clean stays crisp). Movement-gated so still shots stay still.
  var moving=sc.movement&&sc.movement.toLowerCase().indexOf('static')<0;
  if(moving&&fin==='balanced')parts.push('subtle natural motion blur on anything in motion, consistent with a 180-degree shutter, never frozen razor-sharp');
  return parts.join('; ');
}

// ─── EYE DETAIL DERIVER ───
// The #1 uncanny-valley tell is dead eyes. Causal tokens only (what the eyes SEE and
// what LIGHT hits the cornea) — never adjective praise ("beautiful realistic eyes"
// over-renders into glossy CGI). Gated to ECU/CU/MCU where eyes actually resolve;
// wide shots waste attention budget on invisible detail. Budget: max 4 img tokens.
// Kling deliberately gets NOTHING (MOTION_TEXTURE already covers blink; verbose eye
// grammar degrades Kling). Seedance gets +2 motion tokens MOTION_TEXTURE lacks.
var EYE_SHOTS={'ECU':1,'CU':1,'MCU':1};
function eyeDetail(sc,tier){
  if(!sc.shotType||!EYE_SHOTS[sc.shotType])return'';
  if(sc.brollOnly)return'';
  if(sc.shotType==='POV')return'';
  var lit=arrS(sc.lighting).toLowerCase()+' '+arrS(sc.lightQuality).toLowerCase();
  var env=((sc.location||'')+' '+(sc.time||'')).toLowerCase();
  // Catchlight bound to the scene's actual light source — a catchlight that matches
  // the key light is what reads as "alive"; a generic one reads as painted-on.
  var src;
  if(/window/.test(lit+' '+env))src='the window light';
  else if(/golden|sunset|sunrise|sun|dawn|dusk|noon|day|morning|afternoon/.test(lit+' '+env))src='the sunlight';
  else if(/neon/.test(lit+' '+env))src='the neon signs';
  else if(/practical|lamp|candle|screen|tv|fire/.test(lit+' '+env))src='the practical lights';
  else src='the soft key light';
  var a=['a small catchlight from '+src+' reflected in the cornea, consistent with the scene lighting'];
  a.push('a thin natural moisture sheen on the eyes, subtle wet highlight along the lower waterline');
  // Micro-asymmetry fights robotic mirror-eyes — but contradicts formalist symmetry styles.
  var rsE=resolveStyle();
  if(!(rsE&&rsE.formal))a.push('the two eyes naturally non-identical — slight asymmetry in lid and gaze');
  // Gaze intent: eyes that are LOOKING at something read as human; empty stare reads as a doll.
  var hasDlgE=sc.showDialog&&sc.dialog&&sc.dialog.trim()&&sc.dialog.trim().toUpperCase()!=='NONE';
  var intE=S.proj.intent||'';
  if(hasDlgE||intE==='ugc_review'||intE==='testimonial')a.push('gaze focused directly into the lens with present, engaged intent');
  else if(sc.script)a.push('gaze focused with clear intent on what the subject is doing or seeing in the scene');
  else a.push('gaze resting on a specific point with quiet intent, never an empty stare');
  var out=a.slice(0,4).join('; ');
  if(tier==='seed')out+='; tiny natural eye movements between fixations, the gaze settling and tracking with intent as the action unfolds';
  return out;
}

function lookTokens(sc,target){
  var toks=[];
  function add(key){
    if(!key)return;
    var e=LOOK_DICT[key];
    toks.push(e?e[target]:key);
  }
  var er=effRig(sc);
  add(er.cameraBody);
  add(er.lensType);
  (sc.lighting||[]).forEach(add);
  add(er.visualLook);
  return dedupPhrases(toks.join(', '));
}

// ─── SINGLE CHARACTER RESOLVER ───
// Priority: Flow Canvas character assets linked to this scene COMPLETELY
// suppress global S.chars (never merged — dual descriptions cause morphing).
// Fallback: global S.chars unless brollOnly. An explicitly linked character
// asset overrides brollOnly (explicit user intent wins).
// Returns {source:'asset'|'global'|'none', entries:[{name,token}]}.
function resolveIdentity(sc){
  var links=(S.assetLinks||[]).filter(function(l){return l.sceneId===sc.id;});
  var charAssets=links.map(function(l){
    return(S.assets||[]).find(function(a){return a.id===l.assetId&&a.type==='character';});
  }).filter(Boolean);
  if(charAssets.length){
    return{source:'asset',entries:charAssets.map(function(a){
      return{name:a.name||'Character',token:(a.identityToken&&a.identityToken.trim())||compressWords(a.description,25)};
    })};
  }
  if(sc.brollOnly||!S.chars||!S.chars.length)return{source:'none',entries:[]};
  return{source:'global',entries:S.chars.map(function(ch){
    return{name:ch.name||'Character',token:compressWords(ch.description,25)};
  }).filter(function(e){return e.token.length>3;})};
}

// ─── IDENTITY LOCK (Slot 1) + BOOKEND (final slot) ───
// mode: 'img'    — image prompt lock (full token, design language)
//       'txt2vid'— imperative text lock (full token)
//       'img2vid'— reference-based Temporal Hold: the source image is the
//                  identity authority; NEVER re-describe appearance in text
//                  (conflicting descriptions cause melting). Names only.
function identityLockLines(sc,mode){
  var r=resolveIdentity(sc);
  if(mode==='img2vid'){
    var who=r.entries.length?r.entries.map(function(e){return e.name;}).join(' and ')+', the subject in the source image':'The subject in the source image';
    return'SUBJECT LOCK: '+who+' — preserve exact facial identity, hairstyle, and wardrobe from first frame to final frame, including during motion, turns, and lighting shifts. No morphing, no feature drift.';
  }
  if(!r.entries.length)return'';
  var lines=r.entries.slice(0,3).map(function(e){return'IDENTITY LOCK — '+e.name+': '+e.token+'.';});
  var suffix=mode==='img'
    ?'Render this exact appearance precisely as described.'
    :'This exact face, hair, and wardrobe in every frame, frame one through final frame. Zero morphing, zero feature drift, zero wardrobe change.';
  return lines.join('\n')+' '+suffix;
}

function bookendAnchor(sc,mode){
  if(mode==='img2vid')return'HOLD: identical face and wardrobe as frame one.';
  var r=resolveIdentity(sc);
  if(!r.entries.length)return'';
  var e=r.entries[0];
  return'HOLD: '+e.name+' — '+compressWords(e.token,8)+' — unchanged in every frame.';
}

// ─── KINEMATICS COMPILER ───
// engine: 'kling' (one compact clause) | 'seed' (full axis cue).
// Composes: base move (MOVE_DICT) + Dutch-angle modifier (from shotType)
// + user movementNotes (manual override, appended last).
// Guard: exactly ONE base move per shot — compound motion soup confuses models.
// ─── MOVEMENT DYNAMICS (velocity + parallax vocabulary) ───
// Higgsfield-grade motion reads through TEMPO and PARALLAX, not direction alone:
// "constant radius", "background streaking", "banking velocity". Keys match MOVE_DICT.
var MOVE_DYNAMICS={
  'Pan Left':'deliberate even sweep, new space flowing into frame',
  'Pan Right':'deliberate even sweep, new space flowing into frame',
  'Tilt Up':'measured upward sweep, the vertical reveal unfolding',
  'Tilt Down':'measured downward sweep, the vertical reveal unfolding',
  'Dolly In':'steady accelerating push, foreground elements sliding past the frame edges in parallax',
  'Dolly Out':'smooth receding glide, new environment layers entering frame in parallax',
  'Tracking Shot (follow)':'velocity locked to the subject, environment flowing past in layered foreground-background parallax',
  'Arc Left':'curved glide at constant radius, background rotating behind the subject in parallax',
  'Arc Right':'curved glide at constant radius, background rotating behind the subject in parallax',
  'Crane Up':'smooth rising velocity, ground plane receding below, scene scale expanding',
  'Crane Down':'controlled descending glide, intimacy building as the frame lowers',
  'Handheld (organic)':'organic breathing sway, human micro-corrections, alive imperfect energy',
  'Steadicam (smooth follow)':'floating gimbal glide, silky continuous flow through the space',
  'Whip Pan':'violent pan velocity, full directional motion smear, hard stop on the new framing',
  'Rack Focus':'focus plane traveling deliberately between depth layers, bokeh blooming and resolving',
  'Drone (aerial)':'sweeping aerial velocity with a gentle banking curve, landscape parallax unfolding below',
  'Zoom In':'controlled optical zoom tempo, compression building steadily on the subject',
  'Zoom Out':'even optical zoom-out tempo, the scene context expanding',
  'Dolly Zoom (Vertigo)':'opposing dolly and zoom velocities, background visibly stretching while the subject holds exact size',
  '360 Orbit (kinetic)':'constant-radius kinetic orbit, background streaking in motion-blurred parallax while the subject stays tack sharp',
  'Crash Zoom':'explosive zoom velocity, hard background compression, motion blur at the frame edges',
  'Snorricam (body-mounted)':'subject rigidly locked to frame while the world swims and lurches around them',
  'Rise + Tilt Reveal':'accelerating vertical rise, the reveal unfolding in layered parallax',
  'Push-in + Dutch Roll':'accelerating push combined with a slow continuous rotational roll'
};

function buildKinematics(sc,engine){
  var parts=[];
  if(sc.movement){
    var m=MOVE_DICT[sc.movement];
    parts.push(m?m[engine]:sc.movement);
    var dyn=MOVE_DYNAMICS[sc.movement];
    if(dyn)parts.push(dyn);
    // Higgsfield choreography principle: the move frames the subject; the ACTION plays out
    // DURING the move — camera and performance are one choreographed unit, never separate.
    if(sc.script&&sc.movement.indexOf('Static')===-1&&sc.movement!=='Rack Focus')parts.push('the subject\'s action continues naturally throughout the entire move');
  }
  if(sc.shotType==='Dutch Angle')parts.push('canted Dutch angle — horizon deliberately tilted');
  if(sc.movementNotes&&sc.movementNotes.trim())parts.push(sc.movementNotes.trim());
  return parts.join('; ');
}

// ─── MOTION-TEXTURE DICTIONARY (video realism vocabulary) ───
// Same lesson as the image chain: physical rendering language outperforms generic
// "quality" strings ("fluid motion, no glitch" tells the model nothing). Two dialects.
var MOTION_TEXTURE={
  kling:'natural body micro-movement — breathing, blinking, subtle weight shifts; hair and fabric respond physically to every motion',
  seed:'natural body micro-movement — breathing, blinking, subtle weight shifts and small head turns; individual hair strands and fabric respond physically to motion and air; realistic motion blur on fast movement; light interacts naturally with moving surfaces'
};

// ─── AMBIENT MOTION DERIVER ───
// Secondary/environmental life auto-derived from existing scene fields (time, lighting,
// location). This is what separates a living shot from a stiff one — never asks for new UI.
function ambientMotion(sc){
  var t=(sc.time||'').toLowerCase(),loc=(sc.location||'').toLowerCase(),lit=arrS(sc.lighting).toLowerCase();
  var a=[];
  if(/golden|sunset|sunrise|morning|dawn|dusk|sun/.test(t+' '+lit))a.push('dust motes drifting in the sunbeams, warm light shifting subtly across surfaces');
  if(/neon|practical|lamp|candle|screen|tv|fire/.test(lit+' '+loc))a.push('practical light sources flicker gently, soft reflections shimmer');
  if(/street|city|park|beach|market|outdoor|forest|garden|rooftop|road|terrace|plaza/.test(loc))a.push('background life in soft motion — foliage, passersby or distant movement');
  if(/night/.test(t)&&!a.length)a.push('subtle atmospheric depth in the low light');
  if(!a.length)a.push('subtle ambient environment motion — air presence, soft background life');
  return a.slice(0,2).join('; ');
}

// ─── LAST-FRAME DERIVER ───
// Video models drift without a defined end-state (Worldbuilder "Last Frame" principle,
// generalized). Auto-derived: directional moves end on their spatial consequence;
// static/organic moves end on an emotional resolution from mood.
var MOVE_ENDSTATE={
  'Dolly In':'ends framed tighter on the subject',
  'Zoom In':'ends on a tighter framing of the subject',
  'Crash Zoom':'ends hard on a tight framing of the subject',
  'Dolly Out':'ends wider, subject smaller within the revealed environment',
  'Zoom Out':'ends on a wider framing of the scene',
  'Crane Up':'ends on an elevated overview of the scene',
  'Rise + Tilt Reveal':'ends on a high revealing overview of the scene below',
  'Crane Down':'ends close and intimate with the subject',
  'Arc Left':'ends holding the subject from a new side angle',
  'Arc Right':'ends holding the subject from a new side angle',
  '360 Orbit (kinetic)':'ends near the starting angle, subject sharp and center-locked',
  'Dolly Zoom (Vertigo)':'ends with the background visibly stretched behind an unchanged subject',
  'Tracking Shot (follow)':'ends with the subject still perfectly framed mid-motion',
  'Whip Pan':'ends locked hard on the new framing',
  'Push-in + Dutch Roll':'ends close on the subject with a fully canted horizon',
  'Tilt Up':'ends framed on the newly revealed upper view',
  'Tilt Down':'ends framed on the newly revealed lower view',
  'Pan Left':'ends on the newly revealed left side of the scene',
  'Pan Right':'ends on the newly revealed right side of the scene'
};
function deriveLastFrame(sc){
  var hasId=S.videoMode==='img2vid'||resolveIdentity(sc).entries.length>0;
  var idBit=hasId?', subject identity and wardrobe unchanged':'';
  var m=sc.movement&&MOVE_ENDSTATE[sc.movement];
  if(m)return m+idBit;
  var moodBit=sc.mood?', '+sc.mood+' expression held':'';
  return 'settles with the composition at rest'+(hasId?', subject holding their gaze'+moodBit:'')+idBit;
}

// ─── FRAME MAP (Seedance only) ───
// Light spatial anchoring: screen position + gaze. Kling deliberately excluded —
// verbose spatial grammar degrades Kling; it wants short labeled lines.
function frameMapLine(sc){
  if(!sc.shotType)return'';
  if(sc.shotType==='POV')return'FRAME MAP: first-person POV — no subject visible in frame, hands may enter naturally';
  var r=resolveIdentity(sc);
  var isI2VFM=S.videoMode==='img2vid';
  if(!r.entries.length&&!isI2VFM)return'';
  var who=r.entries.length?r.entries.map(function(e){return e.name;}).join(' and '):'the subject';
  var hasDlgFM=sc.showDialog&&sc.dialog&&sc.dialog.trim()&&sc.dialog.trim().toUpperCase()!=='NONE';
  var intentFM=S.proj.intent||'';
  var gaze=(hasDlgFM||intentFM==='ugc_review'||intentFM==='testimonial')?'gaze toward camera, direct natural address':'gaze naturally motivated by the action, not camera-aware';
  return'FRAME MAP: '+who+' anchored at a stable screen position per the '+sc.shotType+' framing, consistent depth layer, '+gaze;
}

// ─── DIEGETIC AUDIO DERIVER (Seedance only) ───
// Rules-based, no API. Diegetic only — never music, score, or lyrics.
function diegeticAudio(sc){
  var loc=(sc.location||'').toLowerCase(),t=(sc.time||'').toLowerCase();
  var hasDlgAu=sc.showDialog&&sc.dialog&&sc.dialog.trim()&&sc.dialog.trim().toUpperCase()!=='NONE';
  var a=[];
  if(hasDlgAu)a.push('natural voice presence in the space');
  if(/street|city|traffic|market|plaza/.test(loc))a.push('distant city ambience');
  else if(/beach|sea|ocean|coast/.test(loc))a.push('waves and coastal air');
  else if(/forest|park|garden|mountain|field/.test(loc))a.push('soft wind through foliage, distant birds');
  else if(/cafe|coffee|restaurant|bar/.test(loc))a.push('low murmur, cups and cutlery');
  else if(/office|studio|room|apartment|home|loft|interior|kitchen|bedroom|house/.test(loc))a.push('quiet natural room tone');
  if(/rain|storm/.test(loc+' '+t))a.push('rain patter');
  if(!a.length)a.push('natural room tone and subtle environmental ambience');
  return'AUDIO: diegetic only — '+a.slice(0,2).join(', ')+'. No music, no score, no lyrics.';
}

// REALISTIC IMAGE PROMPT — slot hierarchy; shot composition first, identity lock early,
// look-tokens (img tier) replace flat camera labels; brand DNA sanitized and appended last.
function bldImg(sc){
  var p=S.proj;
  var pts=[];

  // 1. SHOT TYPE + COMPOSITION (highest priority — injected first)
  var compDesc=shotToComposition(sc.shotType);
  if(sc.shotType){
    pts.push('SHOT: '+sc.shotType+(compDesc?' — '+compDesc:'')+(sc.shotNotes&&sc.shotNotes.trim()?'. '+sc.shotNotes.trim():''));
  }
  // 1.5 STYLE COMPOSITION GRAMMAR — recognized aesthetic styles carry composition rules
  // (e.g. Wes Anderson = symmetry + planimetric camera) that must sit at primacy position,
  // or they lose to the shot chips and the style silently fails to land.
  var rsImg=resolveStyle();
  if(rsImg)pts.push('COMPOSITION GRAMMAR: '+rsImg.comp);

  // 2. IDENTITY LOCK (asset-aware resolver — suppresses global chars when assets linked)
  var lock=identityLockLines(sc,'img');
  if(lock)pts.push(lock);

  // 3. Visual style (color, texture, atmosphere — NOT composition)
  var sa=styleAnch();
  if(sa)pts.push('VISUAL STYLE: '+sa);

  // 4. Subject / action / environment
  if(sc.script)pts.push(sc.script);
  if(sc.location)pts.push('Location: '+sc.location);
  // Anti-collage guard: a comma/and-listed location is the #1 cause of multi-panel output
  if(sc.location&&/,| and /i.test(sc.location))pts.push('SINGLE CONTINUOUS SCENE: one moment in one location only — never a montage, collage, split screen, or multi-panel layout');
  if(sc.time)pts.push(sc.time);
  if(sc.mood)pts.push(sc.mood+' atmosphere');

  // 5. Optics + light as physical rendering consequences (Look-Token Dictionary, img tier).
  // effRig: recognized style supplies its canonical camera package where the user left blanks.
  var er=effRig(sc);
  var fl=er.focalLength?er.focalLength.replace('—','–'):'';
  var ap=er.aperture?er.aperture.replace('—','–'):'';
  var optics=[fl,ap].filter(Boolean).join(', ');
  var lookImg=lookTokens(sc,'img');
  if(lookImg)pts.push('RENDERING: '+lookImg+(optics?', '+optics:''));
  else if(optics)pts.push('RENDERING: '+optics);
  var lq=arrS(sc.lightQuality);
  if(lq)pts.push(lq+' light quality');
  // 5.5 Exposure decision + scene-motivated optical artifacts (medium-aware, finish-gated).
  // This is what breaks the AI's "perfectly balanced" calculation into a celluloid capture.
  var exp=exposureDecision(sc);
  if(exp)pts.push('EXPOSURE: '+exp);
  var oa=opticArtifacts(sc,'img');
  if(oa)pts.push('OPTICS: '+oa);
  // 5.55 Filmic optics — depth, focus falloff, lens softness, motion blur (frame-level, not skin)
  var fo=filmicOptics(sc);
  if(fo)pts.push('DEPTH & LENS: '+fo);
  // 5.6 Eye life — gated to CU/MCU/ECU (eyeDetail handles the gate + formal skip)
  var eyeI=eyeDetail(sc,'img');
  if(eyeI)pts.push('EYES: '+eyeI);

  // 6. Brand DNA / custom instructions (sanitized, appended near-last — cannot override composition)
  var instr=cleanInstr();
  if(instr)pts.push('Note: '+instr);

  // PHOTOREALISM: positive rendering stack ALWAYS applies (texture/depth baseline — the
  // "too clean" fix). CANDID documentary assumptions are skipped when the user wrote a custom
  // Visual Style (their aesthetic intent wins) OR the resolved style is formalist (formal:true —
  // e.g. Wes Anderson symmetry would be contradicted by "natural asymmetry").
  var cvsEl=document.getElementById('customVisualStyle');
  var hasCustomStyle=cvsEl&&cvsEl.value.trim();
  var formalStyle=rsImg&&rsImg.formal;
  var baseStack=PHOTOREALISM_TECHNICAL;
  if(mediumFor(sc)==='phone')baseStack=baseStack.replace('fine photographic grain, subtle halation on bright highlights','fine digital noise texture, computational sharpness signature');
  // CANDID gate now follows Texture Finish, NOT custom-style presence. Old logic dropped the
  // anti-gloss imperfection tokens the moment a style reference was pasted — exactly backwards
  // for faded/raw references (Super 8, documentary): those NEED the imperfection tokens to win
  // against the model's glossy bias. Only formal styles and an explicit CLEAN finish drop them.
  pts.push((formalStyle||finishLevel()==='clean')?baseStack:(baseStack+PHOTOREALISM_AESTHETIC));
  var ar=p.platform&&p.platform.indexOf('9:16')>-1?'9:16':p.platform&&p.platform.indexOf('4:5')>-1?'4:5':p.platform&&p.platform.indexOf('2.39')>-1?'2.39:1':'16:9';
  var out=joinProse(pts)+'.\nAspect ratio: '+ar+'.';
  var assetBlock=assetSectionFor(sc,true);
  if(assetBlock)out+='\n\n'+assetBlock;
  // Embedded negative — GPT Image 2 / Nano Banana Pro have no separate negative field;
  // a terminal AVOID block is the standard single-prompt pattern.
  out+='\n\nAVOID: '+bldNeg(sc)+'.';
  return out;
}

function bldNeg(sc){
  var neg=['blurry','distorted anatomy','deformed hands','extra fingers','extra limbs','watermark','text overlay','low quality','pixelated','AI artifacts','photo collage','split screen','grid layout','multiple panels','storyboard sheet'];
  // Anti-airbrush aesthetic negatives follow Texture Finish (clean finish = polished look is
  // intentional, drop them); a pasted style reference no longer silently removes them.
  var negList=(finishLevel()==='clean'?PHOTOREALISM_NEGATIVE_TECHNICAL:PHOTOREALISM_NEGATIVE).split(', ');
  // Formalist styles (Wes Anderson, Fincher, Commercial) REQUIRE symmetry / centered
  // composition / controlled lighting — prohibiting them in AVOID (recency position) is
  // exactly why the style never landed. Prune the contradicting tokens.
  var rsNeg=resolveStyle();
  if(rsNeg&&rsNeg.formal)negList=negList.filter(function(t){return !/symmetry|centered|studio-perfect/i.test(t);});
  neg=neg.concat(negList);
  var ap=sc.aperture||'',ln=sc.lensType||'',pt=S.proj.type||'';
  if(ap.indexOf('f/1.2')>-1||ap.indexOf('f/1.4')>-1)neg.push('sharp background','deep focus background');
  if(ap.indexOf('f/11')>-1||ap.indexOf('f/16')>-1)neg.push('bokeh','background blur');
  if(ln.indexOf('Fisheye')>-1)neg.push('straight lines');
  if(pt==='sliceoflife'||pt==='documentary')neg.push('overly polished','artificial studio lighting');
  if(pt==='phoneshoot')neg.push('cinematic anamorphic look','professional studio lighting','tripod-perfect composition','shallow cinema depth of field');
  return neg.join(', ');
}

// KLING — slot hierarchy: [1] identity lock [2] action [3] environment [4] kinematics
// [5] look persistence (vid tier) [6] dialog [7] note [8] output [9] bookend anchor.
function bldKling(sc){
  var p=S.proj,sa=styleAnch();
  var isAnim=p.mode==='animated';
  var isI2V=S.videoMode==='img2vid';
  var vMode=isI2V?'img2vid':'txt2vid';
  var hasDlg=sc.showDialog&&sc.dialog&&sc.dialog.trim()&&sc.dialog.trim().toUpperCase()!=='NONE';
  var kin=buildKinematics(sc,'kling');
  var lock=identityLockLines(sc,vMode);
  var bookend=bookendAnchor(sc,vMode);
  var instr=cleanInstr();

  if(isAnim){
    var art=sc.artStyle||'',col=sc.colorPaletteMood||'',energy=arrS(sc.animEnergy),lit2=arrS(sc.lighting);
    var parts=[];
    if(lock&&!sc.brollOnly)parts.push('[LOCK] '+lock);
    if(sc.script)parts.push('[ACTION] '+sc.script);
    if(hasDlg)parts.push('[DIALOG] "'+sc.dialog.trim()+'" — lip sync, natural delivery');
    if(sc.shotType)parts.push('[SHOT] '+sc.shotType+(shotToComposition(sc.shotType)?' — '+shotToComposition(sc.shotType):''));
    if(kin)parts.push('[CAMERA] '+kin);
    if(art)parts.push('[STYLE] '+art);
    if(col)parts.push('[COLOR] '+col);
    if(energy)parts.push('[ENERGY] '+energy);
    if(lit2)parts.push('[LIGHT] '+lit2);
    if(instr)parts.push('[NOTE] '+instr);
    parts.push('[QUALITY] Smooth fluid animation, stable line work, no artifacts');
    var fmt2=p.platform&&p.platform.indexOf('9:16')>-1?'9:16':'16:9';
    parts.push('[OUTPUT] '+fmt2+', 4-6s');
    if(bookend)parts.push('[ANCHOR] '+bookend);
    var klingAnimOut=parts.join('\n');
    var klingAnimAssetBlock=assetSectionFor(sc,true);
    return klingAnimAssetBlock?klingAnimOut+'\n\n'+klingAnimAssetBlock:klingAnimOut;
  }

  // Realistic
  var parts=[];
  if(lock)parts.push(lock);
  if(sc.script)parts.push('ACTION: '+sc.script);
  if(sc.location||sc.time)parts.push('LOCATION: '+(sc.location||'')+(sc.time?' at '+sc.time:''));
  var camLine=(shotToLabel(sc.shotType)||'')+(kin?(sc.shotType?' — ':'')+kin:'');
  if(camLine)parts.push('CAMERA: '+camLine);
  // Style anchor only for txt2vid (img2vid style is locked in the source image)
  if(!isI2V&&sa)parts.push('STYLE: '+sa.split('.')[0]);
  // Mood drives motion energy & performance pacing even in img2vid (vibe is not in the pixels)
  if(sc.mood)parts.push('MOOD: '+sc.mood+' energy in performance and pacing');
  // Look persistence tokens (vid tier) — temporal rendering cues, never a re-grade
  var lookVid=lookTokens(sc,'vid');
  if(lookVid)parts.push('LOOK: '+lookVid);
  // Motion realism: physical texture + ambient environment life (compact Kling dialect).
  // Phone medium adds its authentic capture signature (micro-shake, exposure adaptation).
  var medK=mediumFor(sc);
  parts.push('MOTION: '+MOTION_TEXTURE.kling+'; '+ambientMotion(sc)+(medK==='phone'?'; authentic handheld micro-shake, brief exposure adaptation as framing changes':''));
  var oaK=opticArtifacts(sc,'kling');
  if(oaK)parts.push('OPTICS: '+oaK);
  // Compact end-state — undirected clips drift
  parts.push('END: '+deriveLastFrame(sc));
  if(hasDlg)parts.push(isPerfDialog(sc)?'PERFORMANCE: the artist lip-syncs and performs to their track — expressive singing mouth movement, emotionally connected delivery, performance energy in the whole body':'DIALOG: "'+sc.dialog.trim()+'" — natural lip sync');
  if(instr)parts.push('NOTE: '+instr);
  var fmt=p.platform&&p.platform.indexOf('9:16')>-1?'9:16':p.platform&&p.platform.indexOf('16:9')>-1?'16:9':'9:16';
  parts.push('OUTPUT: '+fmt+', 4-6s, no anatomy distortion');
  if(bookend)parts.push(bookend);
  var klingOut=parts.filter(Boolean).join('\n');
  var klingAssetBlock=assetSectionFor(sc,true);
  return klingAssetBlock?klingOut+'\n\n'+klingAssetBlock:klingOut;
}

// SEEDANCE — slot hierarchy with full-axis kinematics and vid-tier look persistence.
function bldSeed(sc){
  var p=S.proj,sa=styleAnch();
  var isAnim=p.mode==='animated';
  var isI2V=S.videoMode==='img2vid';
  var vMode=isI2V?'img2vid':'txt2vid';
  var hasDlg=sc.showDialog&&sc.dialog&&sc.dialog.trim()&&sc.dialog.trim().toUpperCase()!=='NONE';
  var kin=buildKinematics(sc,'seed');
  var lock=identityLockLines(sc,vMode);
  var bookend=bookendAnchor(sc,vMode);
  var instr=cleanInstr();

  var parts=[];
  // Slot 1: identity lock dominates the attention budget
  if(lock)parts.push(lock);
  // Slot 2: action
  if(sc.script)parts.push('ACTION: '+sc.script);
  if(hasDlg)parts.push(isPerfDialog(sc)?'PERFORMANCE: the artist lip-syncs and performs to their track — expressive singing mouth movement, breath and phrasing visible, emotionally connected delivery, performance energy in the whole body':'DIALOGUE: "'+sc.dialog.trim()+'" — precise lip sync, natural mouth movement');
  // Slot 3: kinematics
  if(sc.shotType)parts.push('SHOT TYPE: '+(isAnim?sc.shotType+(shotToComposition(sc.shotType)?' — '+shotToComposition(sc.shotType):''):shotToLabel(sc.shotType)));
  if(kin)parts.push('CAMERA MOVEMENT: '+kin);
  // Slot 4: environment
  if(sc.location||sc.time)parts.push('LOCATION: '+(sc.location||'')+(sc.time?' at '+sc.time:''));
  if(sc.mood)parts.push('MOOD: '+sc.mood);
  // Slot 5: style/look
  if(isAnim){
    if(sc.artStyle)parts.push('ART STYLE: '+sc.artStyle);
    if(sc.colorPaletteMood)parts.push('COLOR: '+sc.colorPaletteMood);
    if(sc.animEnergy&&sc.animEnergy.length)parts.push('ENERGY: '+arrS(sc.animEnergy));
    if(sc.lighting&&sc.lighting.length)parts.push('LIGHTING: '+arrS(sc.lighting));
    if(!isI2V&&sa)parts.push('VISUAL STYLE: '+sa);
  } else {
    if(!isI2V&&sa)parts.push('VISUAL STYLE: '+sa);
    var lookVid=lookTokens(sc,'vid');
    if(lookVid)parts.push('LOOK PERSISTENCE: '+lookVid);
  }
  // Slot 5.5: spatial anchoring (Worldbuilder Frame Map principle, Seedance dialect)
  var fm=frameMapLine(sc);
  if(fm&&!isAnim)parts.push(fm);
  // Slot 6: custom (sanitized)
  if(instr)parts.push('CUSTOM: '+instr);
  // Slot 7: motion realism replaces the generic quality string — physical texture,
  // ambient environment life, defined end-state, diegetic audio (full Seedance dialect)
  if(!isAnim){
    var medS=mediumFor(sc);
    parts.push('MOTION REALISM: '+MOTION_TEXTURE.seed+(medS==='phone'?'; authentic phone capture — handheld micro-jitter survives stabilization, momentary exposure adaptation and brief focus hunting as the camera moves':''));
    parts.push('AMBIENT MOTION: '+ambientMotion(sc));
    var eyeS=eyeDetail(sc,'seed');
    if(eyeS)parts.push('EYE LIFE: '+eyeS);
    var foS=filmicOptics(sc);
    if(foS)parts.push('DEPTH & LENS: '+foS);
    var expS=exposureDecision(sc);
    if(expS)parts.push('EXPOSURE: '+expS);
    var oaS=opticArtifacts(sc,'seed');
    if(oaS)parts.push('OPTICS: '+oaS);
    parts.push('LAST FRAME: '+deriveLastFrame(sc));
    parts.push(diegeticAudio(sc));
  } else {
    parts.push('QUALITY: Fluid natural motion, no glitch, no anatomy distortion');
  }
  var ar=p.platform&&p.platform.indexOf('9:16')>-1?'9:16':p.platform&&p.platform.indexOf('2.39')>-1?'2.39:1':'16:9';
  parts.push('OUTPUT: '+ar+', 4-6 seconds');
  // Slot 8: bookend anchor (recency bias exploit)
  if(bookend)parts.push(bookend);
  var seedOut=parts.join('\n');
  var seedAssetBlock=assetSectionFor(sc,true);
  return seedAssetBlock?seedOut+'\n\n'+seedAssetBlock:seedOut;
}

// ANIMATED IMAGE PROMPT — punctuation-safe prose join, asset-aware identity lock.
function bldAnimImg(sc){
  var p=S.proj,sa=styleAnch();
  var lock=identityLockLines(sc,'img');
  var pts=[];
  if(sa)pts.push('VISUAL STYLE: '+sa);
  if(sc.artStyle)pts.push(sc.artStyle);
  if(sc.colorPaletteMood)pts.push(sc.colorPaletteMood+' color palette');
  var compDesc=shotToComposition(sc.shotType);
  if(sc.shotType)pts.push('SHOT: '+sc.shotType+(compDesc?' — '+compDesc:'')+(sc.shotNotes&&sc.shotNotes.trim()?'. '+sc.shotNotes.trim():''));
  if(lock)pts.push(lock);
  if(sc.script)pts.push(sc.script);
  if(sc.location)pts.push('Setting: '+sc.location);
  if(sc.time)pts.push(sc.time);
  if(sc.mood)pts.push(sc.mood+' atmosphere');
  if(sc.lighting&&sc.lighting.length)pts.push('Lighting: '+arrS(sc.lighting));
  if(sc.animEnergy&&sc.animEnergy.length)pts.push(arrS(sc.animEnergy)+' energy');
  var instr=cleanInstr();
  if(instr)pts.push(instr);
  pts.push('High quality illustration, sharp clean artwork, professional animation production quality');
  var ar=p.platform&&p.platform.indexOf('9:16')>-1?'9:16':p.platform&&p.platform.indexOf('4:5')>-1?'4:5':'16:9';
  var animOut=joinProse(pts)+'.\nAspect ratio: '+ar+'.';
  var animAssetBlock=assetSectionFor(sc,true);
  return animAssetBlock?animOut+'\n\n'+animAssetBlock:animOut;
}

