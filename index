// Build movement string for video prompts
function assetSectionFor(sc,skipChars){
  var links=(S.assetLinks||[]).filter(function(l){return l.sceneId===sc.id;});
  if(skipChars){links=links.filter(function(l){
    var a=(S.assets||[]).find(function(x){return x.id===l.assetId;});
    return !(a&&a.type==='character');
  });}
  if(!links.length)return'';
  var lines=links.map(function(l){
    var asset=(S.assets||[]).find(function(a){return a.id===l.assetId;});
    if(!asset)return null; // link survived but asset was deleted somehow — skip defensively
    var typeLabel=asset.type?'['+asset.type.charAt(0).toUpperCase()+asset.type.slice(1)+'] ':'';
    var desc=asset.description?asset.description.trim():'';
    var instr=l.instruction?l.instruction.trim():'';
    var bits=[];
    if(desc)bits.push(desc);
    if(instr)bits.push(instr);
    return '- '+typeLabel+(asset.name||'Untitled')+(bits.length?': '+bits.join(' — '):'');
  }).filter(Boolean);
  if(!lines.length)return'';
  return 'ASSETS IN SCENE:\n'+lines.join('\n');
}

