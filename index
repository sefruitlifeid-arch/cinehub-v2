function parseSceneTechSuggestions(){
  var raw=document.getElementById('techPasteField').value.trim();
  if(!raw){alert('Paste the AI response first.');return;}
  var isAnimated=S.proj.mode==='animated';
  function gf(line,key){var rx=new RegExp('\\|\\s*'+key+':\\s*([^|]+)','i');var m=line.match(rx);return m?m[1].trim():'';}
  function matchFullOption(shortVal,optList){
    if(!shortVal)return'';
    var needle=shortVal.toLowerCase().trim();
    var found=optList.find(function(o){return o.split('—')[0].trim().toLowerCase()===needle;});
    if(found)return found;
    found=optList.find(function(o){return o.toLowerCase().indexOf(needle)>-1||needle.indexOf(o.split('—')[0].trim().toLowerCase())>-1;});
    return found||shortVal;
  }

  var sceneLines=raw.split('\n').filter(function(l){return l.trim().toUpperCase().match(/^SCENE_/);});
  if(!sceneLines.length){alert('No SCENE_ lines found.');return;}

  if(isAnimated){
    // ── ANIMATED parse ──────────────────────────────────────────────────────
    // Project-level: ART_STYLE + VISUAL_LOOK
    var projLineA=raw.split('\n').find(function(l){return l.trim().toUpperCase().match(/^PROJECT_ART_STYLE/);});
    var projArtStyle='',projLookA='';
    if(projLineA){
      var asM=projLineA.match(/PROJECT_ART_STYLE:\s*([^|]+)/i);if(asM)projArtStyle=matchFullOption(asM[1].trim(),DD_ANIM.artStyle);
      var lkM=projLineA.match(/PROJECT_VISUAL_LOOK:\s*([^|]+)/i);if(lkM)projLookA=matchFullOption(lkM[1].trim(),DD_REAL.visualLook);
    }
    var emptyA=S.scenes.filter(function(sc){return !sc.artStyle&&!sc.colorPaletteMood&&(!sc.animEnergy||!sc.animEnergy.length)&&!sc.composition;});
    if(!emptyA.length){alert('No scenes with empty animation fields to apply suggestions to.');return;}
    var nA=Math.min(sceneLines.length,emptyA.length);
    for(var i=0;i<nA;i++){
      var line=sceneLines[i],sc=emptyA[i];
      var stV=gf(line,'SHOT_TYPE');if(stV)sc.shotType=stV;
      var mvV=gf(line,'MOVEMENT');if(mvV)sc.movement=mvV;
      var artV=gf(line,'ART_STYLE');if(artV)sc.artStyle=matchFullOption(artV,DD_ANIM.artStyle);
      var colV=gf(line,'COLOR_PALETTE_MOOD');if(colV)sc.colorPaletteMood=matchFullOption(colV,DD_ANIM.colorPaletteMood);
      var compV=gf(line,'COMPOSITION');if(compV)sc.composition=matchFullOption(compV,DD_ANIM.composition);
      var aeV=gf(line,'ANIMATION_ENERGY');if(aeV){
        var matched=CHIP.animEnergy.find(function(e){return e.toLowerCase().indexOf(aeV.toLowerCase())>-1||aeV.toLowerCase().indexOf(e.toLowerCase())>-1;});
        sc.animEnergy=matched?[matched]:(aeV?[aeV]:[]);
      }
      var litA=gf(line,'LIGHTING');sc.lighting=litA?litA.split(',').map(function(s){return s.trim();}).filter(Boolean):[];
      if(projArtStyle&&!sc.artStyle)sc.artStyle=projArtStyle;
      if(projLookA&&!sc.visualLook)sc.visualLook=projLookA;
    }
    if(projArtStyle||projLookA){
      S.scenes.forEach(function(sc){
        if(projArtStyle&&!sc.artStyle)sc.artStyle=projArtStyle;
        if(projLookA&&!sc.visualLook)sc.visualLook=projLookA;
      });
    }
    save();renderScenes();
    var resA=document.getElementById('techApplyRes');
    resA.style.display='block';
    resA.textContent='Applied suggestions to '+nA+' scene(s).'+(projArtStyle?' Art style: '+projArtStyle+'.':'');
    setTimeout(function(){resA.style.display='none';},5000);

  } else {
    // ── REALISTIC parse ──────────────────────────────────────────────────────
    var projLine=raw.split('\n').find(function(l){return l.trim().toUpperCase().match(/^PROJECT_CAMERA_BODY/);});
    var projCamera='',projLook='';
    if(projLine){
      var camM=projLine.match(/PROJECT_CAMERA_BODY:\s*([^|]+)/i);if(camM)projCamera=matchFullOption(camM[1].trim(),DD_REAL.cameraBody);
      var lookM=projLine.match(/PROJECT_VISUAL_LOOK:\s*([^|]+)/i);if(lookM)projLook=matchFullOption(lookM[1].trim(),DD_REAL.visualLook);
    }
    var emptyScenes=S.scenes.filter(function(sc){return !sc.shotType&&!sc.movement&&!sc.cameraBody&&!sc.lensType&&!sc.visualLook;});
    if(!emptyScenes.length){alert('No scenes with empty technical fields to apply suggestions to.');return;}
    var n=Math.min(sceneLines.length,emptyScenes.length);
    for(var j=0;j<n;j++){
      var ln=sceneLines[j],s=emptyScenes[j];
      s.shotType=gf(ln,'SHOT_TYPE');
      s.movement=gf(ln,'MOVEMENT');
      var mn=gf(ln,'MOVEMENT_NOTES');s.movementNotes=(mn&&mn.toUpperCase()!=='NONE')?mn:'';
      s.lensType=matchFullOption(gf(ln,'LENS_TYPE'),DD_REAL.lensType);
      s.focalLength=matchFullOption(gf(ln,'FOCAL_LENGTH'),DD_REAL.focalLength);
      s.aperture=matchFullOption(gf(ln,'APERTURE'),DD_REAL.aperture);
      var lit=gf(ln,'LIGHTING');s.lighting=lit?lit.split(',').map(function(x){return x.trim();}).filter(Boolean):[];
      var lq=gf(ln,'LIGHT_QUALITY');s.lightQuality=lq?lq.split(',').map(function(x){return x.trim();}).filter(Boolean):[];
      if(projCamera)s.cameraBody=projCamera;
      if(projLook)s.visualLook=projLook;
    }
    if(projCamera||projLook){
      S.scenes.forEach(function(sc){
        if(projCamera&&!sc.cameraBody)sc.cameraBody=projCamera;
        if(projLook&&!sc.visualLook)sc.visualLook=projLook;
      });
    }
    save();renderScenes();
    var res=document.getElementById('techApplyRes');
    res.style.display='block';
    res.textContent='Applied suggestions to '+n+' scene(s).'+(projCamera?' Camera: '+projCamera+'.':'')+(projLook?' Look: '+projLook+'.':'');
    setTimeout(function(){res.style.display='none';},5000);
  }
}

