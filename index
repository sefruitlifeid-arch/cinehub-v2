    h+='<div style="margin-bottom:4px;display:flex;gap:5px;align-items:center;"><span class="bA">Image Prompt</span><span style="font-size:10px;color:#52525b;">GPT Image 2 / Nano Banana Pro / Higgsfield · negative embedded as AVOID block</span></div>';
    h+='<div class="pbox" style="margin-bottom:10px;">'+escapeHtml(imgP)+'<button class="cpBtn" data-cpel="oi'+sc.id+'">Copy</button></div>';
