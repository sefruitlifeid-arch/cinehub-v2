// Kling — official multi_prompt structure: per-shot index/prompt/duration, max 6 shots. Uses FRAMING + MOVEMENT GUIDE.
function bldStoryboardKling(){
  var sb=S.storyboard,panels=sb.panels;
  var h=(panels.length>6)?('⚠ Kling multi_prompt supports max 6 shots. You have '+panels.length+' panels — showing first 6, group remaining panels per shot or split into a second video.\n\n'):'';
  var shots=panels.slice(0,6);
  var totalDur=parseInt(sb.duration)||15;
  var perShot=Math.max(1,Math.floor(totalDur/(shots.length||1)));
  var charDesc=S.chars.length?S.chars.map(function(ch){return(ch.name||'character')+': '+ch.description;}).join(' | '):'';
  if(charDesc)h+='BIND SUBJECT: '+charDesc+' — lock identity across all shots.\n\n';
  h+='multi_prompt:\n';
  shots.forEach(function(p,i){
    var fLabel=p.function?'['+p.function+'] ':'';
    var mg=p.movementGuide||{};
    var moveStr;
    if(mg.move){
      moveStr=mg.move.replace(/_/g,' ')+(mg.speed?' ('+mg.speed+')':'')+(mg.subjectLock?', locked on '+mg.subjectLock:'');
    } else {
      moveStr='static';
    }
    var framingStr=p.framing?p.framing+' — ':'';
    h+='{ index: '+(i+1)+', duration: "'+perShot+'", prompt: "'+fLabel+framingStr+(p.beat||'')+'. Camera: '+moveStr+(sb.colorGrade?', '+sb.colorGrade:'')+'" }\n';
  });
  h+='\nOUTPUT: '+(sb.outputAspectRatio||'16:9')+', '+totalDur+'s total, smooth transitions between shots, no anatomy distortion across cuts.';
  return h;
}

