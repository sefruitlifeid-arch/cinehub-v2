// Seedance — per-panel motion reference list (framing = starting composition, movement = how camera moves from there)
function bldStoryboardSeedance(){
  var sb=S.storyboard,panels=sb.panels;
  var h='Animate this @image as a '+(sb.duration||'15')+'-second '+(sb.vibe||'')+' sequence.\n';
  h+='Use '+(sb.cutStyle||'')+' cuts, '+(sb.colorGrade||'')+' grading.\n';
  h+='OUTPUT: '+(sb.outputAspectRatio||'16:9')+'.\n';
  var captureLabel2=getCaptureStyleLabel(sb.captureStyle),captureDesc2=getCaptureStyleDesc(sb.captureStyle);
  if(captureLabel2)h+='Capture style: '+captureLabel2+(captureDesc2?' — '+captureDesc2:'')+'.\n';
  if(panels&&panels.length){
    h+='\nPER-PANEL MOTION (framing = starting composition already locked in the image; movement = how the camera moves from there):\n';
    panels.forEach(function(p,i){
      var mg=p.movementGuide||{};
      var moveStr;
      if(mg.move){
        moveStr='Camera: '+mg.move.replace(/_/g,' ')+(mg.speed?', '+mg.speed:'')+(mg.subjectLock?', subject lock on '+mg.subjectLock:'')+(mg.stability?', '+mg.stability:'');
      } else {
        moveStr='Camera: static';
      }
      h+=(i+1)+'. ['+(p.framing||'unspecified framing')+'] '+moveStr+(mg.durationHint?' ('+mg.durationHint+')':'')+'\n';
    });
  }
  return h.trim();
}

// Seedance — WHOLE MOVEMENT PROMPT generator: builds a prompt asking an external AI to write the single
// flowing animation-treatment paragraph (creative synthesis task, not field assembly — see discussion notes).
// This does NOT assemble the final paragraph itself; it produces the instructions for ChatGPT/Claude/Gemini to write it.
function genWholeMovementPrompt(){
  collectStoryboardForm();
  save();
  var sb=S.storyboard,panels=sb.panels,p=S.proj;
  if(!panels.length){alert('Add and import panels first.');return;}

  var charDesc=S.chars.length?S.chars.map(function(ch){return(ch.name||'character')+': '+ch.description;}).join(' | '):'';
  var captureLabel3=getCaptureStyleLabel(sb.captureStyle),captureDesc3=getCaptureStyleDesc(sb.captureStyle);
  var creativeCtx='\n\nCREATIVE DIRECTION:\nDuration: '+(sb.duration||'15')+'s\nVibe: '+(sb.vibe||'')+'\nPacing: '+(sb.cutStyle||'')+'\nColor grade: '+(sb.colorGrade||'')+'\nOutput aspect ratio: '+(sb.outputAspectRatio||'16:9')+(captureLabel3?'\nDefault capture style: '+captureLabel3+(captureDesc3?' — '+captureDesc3:''):'')+'\n';
  var arcCtx=sb.narrativeArc?('\n\nNARRATIVE ARC:\n'+sb.narrativeArc+'\n'):'';
  var charCtx=charDesc?('\n\nCHARACTERS:\n'+charDesc+'\n'):'';

  var panelCtx='\n\nSTORYBOARD PANELS (read all of these together — do not describe them one by one in your output):\n';
  var povPanelNums=[];
  panels.forEach(function(pn,i){
    var mg=pn.movementGuide||{};
    var moveStr=mg.move?(mg.move.replace(/_/g,' ')+(mg.speed?' ('+mg.speed+')':'')):'static';
    var isPov=(pn.framing||'').toUpperCase()==='POV';
    if(isPov)povPanelNums.push(i+1);
    panelCtx+=(i+1)+'. ['+(pn.function||'')+'] framing: '+(pn.framing||'unspecified')+(isPov?' (POV — only ONE character visible in frame, viewer sees through their eyes)':'')+' — beat: '+(pn.beat||'')+' — movement: '+moveStr+'\n';
  });

  var task='\n\nTASK:\nWrite ONE single flowing paragraph — an animation treatment, the way a director would describe how to bring this storyboard image to life — to be pasted into Seedance to animate the finished storyboard grid image as one continuous video.\n\n';

  var rules='RULES:\n'
    +'1. This is creative synthesis, not a panel-by-panel summary. Read all panels as a whole, understand the emotional/narrative progression, and describe the overall motion language of the film. Do NOT write "Panel 1... Panel 2..." or otherwise itemize panels — if your output could be confused with a numbered shot list, you are doing it wrong.\n'
    +'2. Group panels into narrative/emotional clusters (e.g. "the restless nighttime moments", "the product interaction moment", "the restful morning moments") and assign differentiated camera handling per cluster rather than one blanket camera feel for the whole video — e.g. subtle handheld intimacy for personal/emotional moments, controlled gimbal precision for product moments, gentle floating movement for resolution/uplifting moments. Use your own judgment on the right clusters and handling for this specific storyboard, the examples above are illustrative only.\n'
    +(povPanelNums.length?('2b. CRITICAL — FRAMING ACCURACY: panels '+povPanelNums.join(', ')+' are POV shots (only one character visible, camera = that character\'s eyes). Do NOT describe POV as the video\'s overall opening style or a blanket treatment for the whole sequence — it applies ONLY to those specific panels. When the narrative reaches a non-POV panel, both/all characters become visible again as the storyboard shows. Never let a panel-specific framing choice (especially POV) get generalized into an instruction that contradicts what other panels actually show.\n'):'')
    +'3. Sound design is OPTIONAL — only include a sound design sentence if specific, evocative, naturally-implied sound cues genuinely emerge from the panel actions (e.g. "bottle cap twist", "phone notification", "footsteps", "paper rustle"). Do not invent generic filler like "cinematic whoosh" or "soft ambience" just to fill a sound design section. If no meaningful cues emerge, omit the sound design sentence entirely.\n'
    +'4. Keep it to one paragraph, roughly 3-6 sentences. Reference the overall duration, vibe, pacing, and color grade naturally within the prose.\n'
    +'5. Output ONLY the paragraph — no preamble, no headers, no markdown, no explanation.';

  var personaWM=getDirectorPersona();
  var intros={chatgpt:'You are '+personaWM+', writing an animation treatment note.\n\n',claude:'<context>\nYou are '+personaWM+', writing an animation treatment note.\n</context>\n\n',gemini:'Act as '+personaWM+', writing an animation treatment note.\n\n'};
  var prompt=(intros[S.aiTool]||intros.chatgpt)+'PROJECT TYPE: '+(p.type||'')+(p.genre?'\nGENRE: '+p.genre:'')+creativeCtx+arcCtx+charCtx+panelCtx+task+rules;

  document.getElementById('sbWholePromptBox').textContent=prompt;
  document.getElementById('sbWholePromptCpBtn').style.display='inline-flex';
}

