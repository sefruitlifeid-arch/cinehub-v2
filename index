// ═══ PARSE PANEL IMPORT — strict pipe-delimited parser ═══
function parseStoryboardImport(){
  var raw=document.getElementById('sbImportField').value.trim();
  if(!raw){alert('Nothing to import');return;}
  var lines=raw.split('\n').filter(function(l){return l.trim().toUpperCase().match(/^PANEL_/);});
  if(!lines.length){alert('No PANEL_ lines found.');return;}
  function gf(line,key){var rx=new RegExp('\\|\\s*'+key+':\\s*([^|]+)','i');var m=line.match(rx);return m?m[1].trim():'';}
  function nn(v){return(!v||v.toUpperCase()==='NONE')?'':v;}
  var parsed=lines.map(function(line,idx){
    var weight=gf(line,'CAPTION_WEIGHT').toLowerCase();
    if(['hero','support','none'].indexOf(weight)===-1)weight='none';
    return{
      id:Date.now()+idx+Math.random(),
      function:gf(line,'FUNCTION'),
      framing:gf(line,'FRAMING'),
      beat:gf(line,'BEAT'),
      movementGuide:{
        move:gf(line,'MOVE'),
        speed:gf(line,'SPEED'),
        subjectLock:gf(line,'SUBJECT_LOCK'),
        stability:gf(line,'STABILITY'),
        durationHint:''
      },
      captionWeight:weight,
      caption:{
        headline:nn(gf(line,'CAPTION_HEADLINE')),
        subtext:nn(gf(line,'CAPTION_SUBTEXT'))
      }
    };
  });
  S.storyboard.panels=S.storyboard.panels.concat(parsed);
  var overflow=S.storyboard.panels.length>12;
  if(overflow)S.storyboard.panels=S.storyboard.panels.slice(0,12);
  save();renderPanels();
  var res=document.getElementById('sbImportRes');res.style.display='block';
  res.textContent='Imported '+parsed.length+' panel(s). Total: '+S.storyboard.panels.length+(overflow?' (capped at 12 max — some imported panels were dropped)':'');
  setTimeout(function(){res.style.display='none';},4000);
}

